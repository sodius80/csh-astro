}</style><style class="wpcode-css-snippet">/* Hide WP-generated page title H1 on Privacy Policy  hero H1 (.csh-ph-title) is the correct one */
.page-id-17 h1:not(.csh-ph-title) { display: none !important; }</style><script>(function() {
  function fixPrices() {
    if (!document.body.classList.contains('postid-93')) return;
    var replacements = [
      ['$65/mo', '$59/mo'],
      ['$49/mo', '$59/mo'],
      ['$129/mo', '$149/mo']
    ];
    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    var node;
    while ((node = walker.nextNode())) {
      var text = node.nodeValue;
      var changed = false;
      replacements.forEach(function(pair) {
        if (text.indexOf(pair[0]) !== -1) {
          text = text.split(pair[0]).join(pair[1]);
          changed = true;
        }
      });
      if (changed) node.nodeValue = text;
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fixPrices);
  } else {
    fixPrices();
  }
})();</script><script>(function() {
  function fixPrices() {
    if (!document.body.classList.contains('postid-23')) return;
    var replacements = [
      ['Core $49/mo (1 user) | Connect $149/mo (up to 5 users) | Grow $199/mo (up to 10 users)', 'Core $29/mo (1 user) | Connect $99/mo (up to 5 users) | Grow $149/mo (up to 10 users, billed annually)'],
      ['Basic $49/mo | Essentials $129/mo | MAX $299/mo', 'Basic $59/mo | Essentials $149/mo | MAX $299/mo']
    ];
    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    var node;
    while ((node = walker.nextNode())) {
      var text = node.nodeValue;
      replacements.forEach(function(pair) {
        if (text.indexOf(pair[0]) !== -1) {
          text = text.split(pair[0]).join(pair[1]);
        }
      });
      node.nodeValue = text;
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fixPrices);
  } else {
    fixPrices();
  }
})();</script><style class="wpcode-css-snippet">.post-93 .csh-hero-stat:first-child { display: none; }</style><style class="wpcode-css-snippet">/* M-19: Remove white gap between content and footer */
/* Kadence adds 5rem margin-bottom to .content-area; footer has its own 48px padding-top */
.content-area { margin-bottom: 0 !important; }

/* Remove extra top margin on the custom footer (padding-top: 48px is sufficient) */
.csh-site-footer { margin-top: 0 !important; }</style><style class="wpcode-css-snippet">/* ================================================================
   CSH Category Archive Styles
   Applied to: /category/* pages (body.category)
   ================================================================ */

/* -- HERO: Dark Navy Background -- */
body.category .post-archive-hero-section {
  background: linear-gradient(135deg, #1C2B4B 0%, #253656 50%, #1C2B4B 100%) !important;
  padding: 0 !important;
}
body.category .entry-hero-container-inner {
  background: transparent !important;
}
body.category .post-archive-hero-section .hero-section-overlay {
  display: none;
}
body.category .post-archive-hero-section .hero-container {
  padding: 20px 24px 48px;
  max-width: 1180px;
}
body.category .post-archive-hero-section .entry-header {
  text-align: left !important;
}

/* Hero H1 */
body.category .archive-title {
  font-family: 'Barlow Condensed', sans-serif !important;
  font-weight: 800 !important;
  font-size: 42px !important;
  color: #fff !important;
  text-transform: uppercase;
  letter-spacing: -.01em;
  line-height: 1.1;
  margin-bottom: 14px !important;
  padding: 0 !important;
}

/* Breadcrumb in hero */
.csh-cat-breadcrumb {
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  color: rgba(255,255,255,.45);
  margin-bottom: 28px;
  padding-top: 4px;
}
.csh-cat-breadcrumb a {
  color: rgba(255,255,255,.55);
  text-decoration: none;
  transition: color .15s;
}
.csh-cat-breadcrumb a:hover { color: #E07A3A; }
.csh-cat-breadcrumb .sep {
  margin: 0 8px;
  color: rgba(255,255,255,.3);
}

/* Override Kadence width:100% on hero child divs */
body.category .entry-hero-container-inner .entry-header > div {
  width: auto !important;
}

/* Eyebrow */
.csh-cat-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #E07A3A;
  margin-bottom: 10px;
  display: inline-block;
  background: rgba(255, 240, 230, 0.15);
  padding: 3px 10px;
  border-radius: 4px;
}

/* Subtitle */
.csh-cat-subtitle {
  font-family: 'Barlow', sans-serif;
  font-size: 16px;
  color: rgba(255,255,255,.65);
  line-height: 1.65;
  max-width: 620px;
  margin: 0;
}

/* Post count badge */
.csh-cat-post-count {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 18px;
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: rgba(255,255,255,.5);
  background: rgba(255,255,255,.08);
  padding: 6px 14px;
  border-radius: 20px;
}
.csh-cat-post-count strong {
  color: #fff;
  font-weight: 700;
}

/* -- CONTENT AREA LAYOUT -- */
body.category .content-container.site-container {
  max-width: 1180px;
  display: flex !important;
  gap: 40px;
  align-items: flex-start;
  padding: 40px 24px 72px;
}
body.category #main.site-main {
  flex: 1;
  min-width: 0;
}

/* -- CATEGORY INTRO BOX -- */
.csh-cat-intro {
  background: #F7F8FA;
  border: 1.5px solid #e2e5ea;
  border-radius: 12px;
  padding: 20px 24px;
  margin-bottom: 32px;
}
.csh-cat-intro p {
  font-size: 14px;
  color: #374151;
  line-height: 1.65;
  margin: 0;
  font-family: 'Barlow', sans-serif;
}
.csh-cat-intro p strong {
  color: #1C2B4B;
  font-weight: 700;
}

/* -- POST GRID: 2 columns -- */
body.category #archive-container.kadence-posts-list {
  display: grid !important;
  grid-template-columns: repeat(2, 1fr) !important;
  gap: 20px !important;
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
}
body.category #archive-container .entry-list-item {
  list-style: none;
  padding: 0 !important;
  margin: 0 !important;
}

/* -- POST CARD STYLING -- */
body.category .loop-entry {
  background: #fff;
  border: 1.5px solid #e2e5ea;
  border-radius: 14px;
  overflow: hidden;
  transition: border-color .2s, box-shadow .2s, transform .2s;
  height: 100%;
  display: flex;
  flex-direction: column;
}
body.category .loop-entry:hover {
  border-color: #E07A3A;
  box-shadow: 0 6px 24px rgba(224,122,58,.12);
  transform: translateY(-2px);
}

/* Card thumbnail */
body.category .loop-entry .post-thumbnail {
  width: 100%;
  height: 180px;
  overflow: hidden;
  flex-shrink: 0;
}
body.category .loop-entry .post-thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Card body */
body.category .loop-entry .entry-content-wrap {
  padding: 20px 22px 22px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Card meta */
body.category .loop-entry .entry-meta {
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  color: #9ca3af;
  margin-bottom: 10px;
}
body.category .loop-entry .entry-meta .posted-by .author {
  font-weight: 600;
  color: #6b7280;
}

/* Card title */
body.category .loop-entry .entry-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 20px;
  color: #1C2B4B;
  line-height: 1.2;
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: -.01em;
}
body.category .loop-entry .entry-title a {
  color: #1C2B4B;
  text-decoration: none;
  transition: color .15s;
}
body.category .loop-entry .entry-title a:hover { color: #E07A3A; }

/* Card excerpt */
body.category .loop-entry .entry-summary p,
body.category .loop-entry .entry-summary {
  font-size: 14px;
  color: #374151;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16px;
  font-family: 'Barlow', sans-serif;
}

/* Card footer link */
body.category .loop-entry .entry-footer .entry-taxonomies {
  display: none;
}
body.category .loop-entry .entry-footer .read-more-wrap {
  margin-top: auto;
}
body.category .loop-entry .entry-footer .entry-readmore {
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: #E07A3A;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: gap .15s, color .15s;
}
body.category .loop-entry .entry-footer .entry-readmore:hover {
  gap: 8px;
  color: #c96928;
}

/* -- SIDEBAR -- */
.csh-cat-sidebar {
  width: 280px;
  flex-shrink: 0;
  position: sticky;
  top: 100px;
}

/* Sidebar widget base */
.csh-cat-sw {
  background: #F7F8FA;
  border: 1.5px solid #e2e5ea;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}
.csh-cat-sw-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #6b7280;
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 2px solid #e2e5ea;
}

/* Category nav list */
.csh-cat-nav-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.csh-cat-nav-list li { margin-bottom: 2px; }
.csh-cat-nav-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: 8px;
  font-family: 'Barlow', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  text-decoration: none;
  transition: background .15s, color .15s;
}
.csh-cat-nav-link:hover {
  background: #fff;
  color: #E07A3A;
}
.csh-cat-nav-link.active {
  background: #1C2B4B;
  color: #fff;
  font-weight: 600;
}
.csh-cat-nav-link.active .csh-cat-count {
  background: rgba(255,255,255,.15);
  color: #E07A3A;
}
.csh-cat-nav-icon {
  width: 20px;
  text-align: center;
  flex-shrink: 0;
  color: #9ca3af;
}
.csh-cat-nav-link.active .csh-cat-nav-icon { color: #E07A3A; }
.csh-cat-count {
  margin-left: auto;
  font-size: 11px;
  font-weight: 700;
  color: #9ca3af;
  background: #e2e5ea;
  padding: 2px 8px;
  border-radius: 10px;
  min-width: 22px;
  text-align: center;
}

/* CTA widget */
.csh-cat-cta {
  background: #1C2B4B !important;
  border: none !important;
  text-align: center;
  padding: 24px 20px;
}
.csh-cat-cta .csh-cat-sw-title {
  color: #E07A3A;
  border-bottom-color: rgba(255,255,255,.1);
}
.csh-cat-cta p {
  font-size: 13px;
  color: rgba(255,255,255,.65);
  line-height: 1.5;
  margin-bottom: 16px;
  font-family: 'Barlow', sans-serif;
}
.csh-cat-cta-btn {
  display: block;
  background: #E07A3A;
  color: #fff;
  font-family: 'Barlow', sans-serif;
  font-weight: 700;
  font-size: 14px;
  padding: 11px 20px;
  border-radius: 6px;
  text-align: center;
  text-decoration: none;
  transition: background .2s;
}
.csh-cat-cta-btn:hover {
  background: #c96928;
  color: #fff;
}

/* -- PAGINATION -- */
body.category .kadence-pagination,
body.category .navigation.pagination {
  display: flex;
  justify-content: center;
  margin-top: 24px;
}

/* -- RESPONSIVE: Tablet <= 900px -- */
@media (max-width: 900px) {
  body.category .archive-title { font-size: 34px !important; }
  body.category .content-container.site-container {
    flex-direction: column !important;
    padding: 32px 24px 56px;
  }
  .csh-cat-sidebar {
    width: 100%;
    position: static;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .csh-cat-sw { margin-bottom: 0; }
  body.category #archive-container.kadence-posts-list {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px !important;
  }
  body.category .loop-entry .post-thumbnail { height: 150px; }
}

/* -- RESPONSIVE: Mobile <= 640px -- */
@media (max-width: 640px) {
  body.category .post-archive-hero-section .hero-container {
    padding: 16px 16px 36px;
  }
  body.category .archive-title { font-size: 28px !important; }
  .csh-cat-subtitle { font-size: 14px; }
  body.category .content-container.site-container {
    padding: 24px 16px 48px;
    gap: 32px;
  }
  body.category #archive-container.kadence-posts-list {
    grid-template-columns: 1fr !important;
    gap: 16px !important;
  }
  body.category .loop-entry .post-thumbnail { height: 180px; }
  body.category .loop-entry .entry-title { font-size: 18px; }
  body.category .loop-entry .entry-content-wrap { padding: 16px 18px 18px; }
  .csh-cat-intro { padding: 16px 18px; margin-bottom: 24px; }
  .csh-cat-sidebar { grid-template-columns: 1fr; }
}

/* -- RESPONSIVE: Small Mobile <= 400px -- */
@media (max-width: 400px) {
  body.category .archive-title { font-size: 24px !important; }
  body.category .loop-entry .entry-title { font-size: 17px; }
  .csh-cat-breadcrumb { font-size: 12px; }
}

/* Hide default Kadence elements we're replacing */
body.category .post-archive-hero-section .hero-section-overlay { display: none; }
body.category #primary.content-area { margin-top: 0 !important; }
</style><style class="wpcode-css-snippet">/* CSH CSS Fixes 2026-03-02 */

/* FIX 1 (Task 5): Roundup Hero Text Contrast */
.csh-ri-eyebrow,
.csh-ri-hero-sub {
  color: rgba(255, 255, 255, 0.80) !important;
}

/* FIX 2 (Task 10): Mobile Comparison Cards Stacking */
@media (max-width: 640px) {
  .csh-comparison-card {
    flex: 1 1 100%;
  }
}

/* FIX 3: Hero Disclaimer Override */
.csh-review-hero-wrap .csh-vc-disclaimer,
.csh-comp-hero-full .csh-vc-disclaimer,
.csh-page-hero-wrap .csh-vc-disclaimer,
.csh-ri-hero .csh-vc-disclaimer {
  color: rgba(255, 255, 255, 0.65) !important;
  font-size: 13px !important;
  margin: 6px 0 0;
}

/* FIX 4 (Task 9): Footer Gap */
.site-content {
  padding-bottom: 0 !important;
}

#inner-wrap > .site-content {
  margin-bottom: 0;
}

.entry-content-wrap {
  padding-bottom: 0;
}

.site-main {
  margin-bottom: 0;
  padding-bottom: 0;
}

.content-area,
.site-content .content-area {
  min-height: 0;
}

.entry-content > *:last-child {
  margin-bottom: 0;
}

/* FIX 5 (Task 6): Hide duplicate page title on All Reviews */
body.page-id-41 .entry-header {
  display: none !important;
}
/* SVG Trade Icons in Review Hero */
.csh-rh-logo-svg {
  background: #1C2B4B;
  padding: 14px;
  border: 1px solid rgba(255,255,255,.06);
}
.csh-rh-logo-svg svg {
  width: 100%;
  height: 100%;
  display: block;
}


/* FIX 6: Review Index Logo Images */
.csh-ri-logo {
  background: #fff;
  border: 1.5px solid #e2e5ea;
  padding: 8px;
  box-sizing: border-box;
}
.csh-ri-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

/* FIX 7: Review Index Page White Space */
body.page-id-41 .entry-content-wrap {
  padding-top: 0 !important;
}
body.page-id-41 #primary.content-area {
  margin-top: 0 !important;
}
body.page-id-41 .csh-breadcrumb {
  margin-bottom: 0 !important;
  padding: 12px 0;
}</style><style class="wpcode-css-snippet">.csh-verdict-card { background: #F8FAFC; border: 2px solid #1C2B4B; border-radius: 12px; padding: 24px; margin-bottom: 32px; }
.csh-vc-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 20px; }
.csh-vc-header-left { flex: 1; min-width: 0; }
.csh-vc-title { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 800; color: #1C2B4B; text-transform: uppercase; letter-spacing: 0.5px; }
.csh-vc-subtitle { font-size: 13px; color: #64748B; margin-top: 4px; }
.csh-vc-tier { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 800; padding: 8px 16px; border-radius: 8px; letter-spacing: 1px; text-transform: uppercase; white-space: nowrap; flex-shrink: 0; }
.csh-vc-tier-top        { background: #D1FAE5; color: #065F46; }
.csh-vc-tier-strong     { background: #DBEAFE; color: #1E40AF; }
.csh-vc-tier-specialist { background: #FEF3C7; color: #92400E; }
.csh-vc-tier-skip       { background: #FEE2E2; color: #991B1B; }
.csh-vc-summary { color: #475569; font-size: 15px; line-height: 1.6; margin-bottom: 20px; }
.csh-vc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 4px; }
.csh-vc-col-head { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
.csh-vc-col-green { color: #065F46; }
.csh-vc-col-red   { color: #991B1B; }
.csh-vc-item { font-size: 14px; color: #475569; padding: 4px 0 4px 20px; position: relative; line-height: 1.4; }
.csh-vc-item::before { position: absolute; left: 0; }
.csh-vc-pro::before  { content: "✓"; color: #10B981; }
.csh-vc-con::before  { content: "✗"; color: #EF4444; }
.csh-vc-cta { margin-top: 20px; }
.csh-vc-btn { display: block; background: #E07A3A; color: #fff !important; padding: 13px 24px; border-radius: 6px; font-size: 15px; font-weight: 600; text-align: center; text-decoration: none; }
.csh-vc-btn:hover { background: #c96928; color: #fff !important; }
.csh-vc-disclaimer { font-size: 12px; color: #94A3B8; margin-top: 8px; text-align: center; }
@media (max-width: 600px) { .csh-vc-header { flex-direction: column; } .csh-vc-grid { grid-template-columns: 1fr; } }
/* Hide old content-embedded hero when new snippet hero is present */
.csh-review-hero-wrap ~ .csh-software-hero { display: none !important; }</style><style class="wpcode-css-snippet">/* CSH: Hide Kadence default entry-header on all pages/posts with custom heroes.
   Loaded via WPCode CSS snippet which outputs after all theme stylesheets,
   ensuring these rules win regardless of Kadence's !important declarations. */

/* Single posts (review + comparison pages) */
body.single-post .entry-header { display: none !important; }

/* Static pages with custom PHP heroes */
body.page-id-129 .entry-header,
body.page-id-121 .entry-header,
body.page-id-120 .entry-header,
body.page-id-17 .entry-header,
body.page-id-19 .entry-header,
body.page-id-130 .entry-header { display: none !important; }

/* Remove content-area top margin on static pages */
body.page-id-129 .content-area,
body.page-id-121 .content-area,
body.page-id-120 .content-area,
body.page-id-17 .content-area,
body.page-id-19 .content-area,
body.page-id-130 .content-area { margin-top: 0 !important; }

/* Remove entry-content-wrap top padding on static pages */
body.page-id-129 .entry-content-wrap,
body.page-id-121 .entry-content-wrap,
body.page-id-120 .entry-content-wrap,
body.page-id-17 .entry-content-wrap,
body.page-id-19 .entry-content-wrap,
body.page-id-130 .entry-content-wrap { padding-top: 0 !important; }

/* ═══════════════════════════════════════════════════════════
   CSS ADDITIONS (Phases 1-4 design parity)
   ═══════════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════════
   CSH DESIGN PARITY — Inner Page Styles
   Added: 2026-03-01
   Phases 1-4: Global elements, review heroes, comparison
   heroes, static page heroes, footer, breadcrumbs
   ═══════════════════════════════════════════════════════════ */

/* ─── PHASE 1A: SITE FOOTER ──────────────────────────────── */
.csh-site-footer {
  background: #1C2B4B;
  padding: 48px 24px 0;
  margin-top: 56px;
  font-family: 'Barlow', sans-serif;
  color: rgba(255,255,255,.65);
}
.csh-footer-inner {
  max-width: 1180px;
  margin: 0 auto;
  display: flex;
  gap: 48px;
  padding-bottom: 36px;
  border-bottom: 1px solid rgba(255,255,255,.1);
}
.csh-footer-brand { flex: 1; min-width: 220px; }
.csh-footer-logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  letter-spacing: .5px;
  margin-bottom: 10px;
}
.csh-footer-logo span { color: #E07A3A; }
.csh-footer-tagline {
  font-size: 14px;
  line-height: 1.6;
  margin: 0;
  max-width: 280px;
}
.csh-footer-nav {
  display: flex;
  gap: 48px;
  flex-wrap: wrap;
}
.csh-footer-col { min-width: 140px; }
.csh-footer-col h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #E07A3A;
  margin: 0 0 14px;
}
.csh-footer-col a {
  display: block;
  font-size: 14px;
  color: rgba(255,255,255,.65) !important;
  text-decoration: none;
  padding: 4px 0;
  transition: color .15s;
}
.csh-footer-col a:hover { color: #fff !important; }
.csh-footer-bottom {
  max-width: 1180px;
  margin: 0 auto;
  padding: 20px 0 24px;
  font-size: 13px;
  text-align: center;
}
.csh-footer-bottom p { margin: 0 0 6px; }
.csh-footer-legal a {
  color: rgba(255,255,255,.65) !important;
  text-decoration: none;
}
.csh-footer-legal a:hover { color: #fff !important; }
.csh-footer-disc {
  font-size: 12px;
  color: rgba(255,255,255,.6);
  margin-top: 8px !important;
}
@media (max-width: 768px) {
  .csh-footer-inner { flex-direction: column; gap: 32px; }
  .csh-footer-nav { gap: 32px; }
}

/* ─── PHASE 1B: BREADCRUMBS ──────────────────────────────── */
.csh-breadcrumb {
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  color: #94A3B8;
  margin-bottom: 20px;
}
.csh-breadcrumb ol {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  align-items: center;
}
.csh-breadcrumb li { display: inline-flex; align-items: center; }
.csh-breadcrumb li:not(:last-child)::after {
  content: "\203A";
  margin: 0 6px;
  color: #CBD5E1;
  font-size: 16px;
}
.csh-breadcrumb a {
  color: #64748B !important;
  text-decoration: none;
}
.csh-breadcrumb a:hover { color: #E07A3A !important; }
.csh-bc-current { color: #1C2B4B; font-weight: 500; }

/* ─── PHASE 1C: GLOBAL INNER PAGE TYPOGRAPHY ─────────────── */
/* Target inner pages only (not homepage, not All Reviews) */
body:not(.home) .entry-content h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 24px;
  text-transform: uppercase;
  letter-spacing: -.01em;
  color: #1C2B4B;
  border-bottom: 2px solid #E2E8F0;
  padding-bottom: 8px;
  margin: 32px 0 16px;
  line-height: 1.2;
}
body:not(.home) .entry-content h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 18px;
  color: #1C2B4B;
  margin: 24px 0 10px;
  line-height: 1.3;
}
body:not(.home) .entry-content p {
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: #374151;
  margin-bottom: 14px;
}
body:not(.home) .entry-content ul,
body:not(.home) .entry-content ol {
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: #374151;
  margin-bottom: 14px;
  padding-left: 22px;
}
body:not(.home) .entry-content li {
  margin-bottom: 4px;
}

/* ─── PHASE 2A: HIDE DEFAULT KADENCE ELEMENTS ON SINGLES ─── */
/* Hide default featured image on single posts */
body.single-post .post-thumbnail,
body.single-post .entry-thumbnail,
body.single-post .kadence-entry-thumbnail,
body.single-post .wp-post-image-wrap,
body.single-post .entry-header .post-thumbnail {
  display: none !important;
}
/* Hide default H1 title on single posts (our hero injects a new one) */
body.single-post .entry-header .entry-title,
body.single-post .entry-header .kadence-entry-title {
  display: none !important;
}
/* Hide page title on pages with heroes */
body.page-id-129 .entry-header .entry-title,
body.page-id-121 .entry-header .entry-title,
body.page-id-120 .entry-header .entry-title,
body.page-id-17 .entry-header .entry-title,
body.page-id-19 .entry-header .entry-title,
body.page-id-130 .entry-header .entry-title {
  display: none !important;
}
/* Remove default top spacing on inner pages */
body.single-post .entry-content-wrap { padding-top: 0 !important; }
body.single-post .content-area { margin-top: 0 !important; }

/* ─── PHASE 2B: REVIEW HERO ──────────────────────────────── */
.csh-review-hero-wrap {
  margin-left: calc(-50vw + 50%);
  margin-right: calc(-50vw + 50%);
  margin-bottom: 28px;
}
.csh-review-hero {
  background: #1C2B4B;
  background-image:
    radial-gradient(ellipse at 60% 0%, rgba(224,122,58,.08) 0%, transparent 50%),
    linear-gradient(160deg, #1C2B4B 60%, #111d33 100%);
  padding: 44px 40px 36px;
}
.csh-rh-inner {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  gap: 28px;
  align-items: flex-start;
}
.csh-rh-logo {
  width: 80px;
  height: 80px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 24px;
  color: #fff;
  box-shadow: 0 4px 12px rgba(0,0,0,.25);
}
.csh-rh-content { flex: 1; min-width: 0; }
.csh-rh-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  color: #E07A3A;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.csh-rh-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 32px;
  font-weight: 800;
  color: #fff;
  line-height: 1.1;
  margin: 0 0 10px;
  letter-spacing: -.01em;
}
body:not(.home) .entry-content .csh-rh-subtitle {
  color: #CBD5E1;
  font-size: 15px;
  line-height: 1.6;
  margin: 0 0 14px;
}
.csh-rh-meta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  align-items: center;
}
.csh-rh-meta-item {
  font-size: 13px;
  color: #94A3B8;
}
.csh-rh-meta-item strong { color: #E2E8F0; }

/* Verdict badges in hero */
.csh-rh-verdict-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 12px;
  border-radius: 20px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
}
.csh-vb-top { background: #D1FAE5; color: #065F46; }
.csh-vb-strong { background: #DBEAFE; color: #1E40AF; }
.csh-vb-specialist { background: #FEF3C7; color: #92400E; }
.csh-vb-skip { background: #FEE2E2; color: #991B1B; }

/* CTA button in hero */
.csh-rh-cta {
  display: inline-block;
  background: #E07A3A;
  color: #fff !important;
  padding: 12px 22px;
  border-radius: 8px;
  font-weight: 700;
  font-size: 14px;
  text-decoration: none !important;
  white-space: nowrap;
  flex-shrink: 0;
  align-self: center;
  transition: background .2s;
}
.csh-rh-cta:hover { background: #c96928; color: #fff !important; }

@media (max-width: 768px) {
  .csh-review-hero { padding: 32px 20px 28px; }
  .csh-rh-inner { flex-direction: column; gap: 16px; }
  .csh-rh-logo { width: 60px; height: 60px; font-size: 20px; }
  .csh-rh-title { font-size: 26px; }
  .csh-rh-cta { width: 100%; text-align: center; }
  .csh-rh-meta { gap: 10px; }
}

/* ─── PHASE 3: COMPARISON HERO (full-width) ──────────────── */
.csh-comp-hero-full {
  margin-left: calc(-50vw + 50%);
  margin-right: calc(-50vw + 50%);
  background: #1C2B4B;
  background-image:
    radial-gradient(ellipse at 50% 0%, rgba(224,122,58,.08) 0%, transparent 50%);
  padding: 48px 40px 40px;
  margin-bottom: 28px;
  text-align: center;
}
.csh-comp-hero-inner {
  max-width: 700px;
  margin: 0 auto;
}
.csh-comp-hero-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  color: #E07A3A;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.csh-comp-hero-h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  color: #fff;
  text-transform: none;
  letter-spacing: 1px;
  margin: 0 0 20px;
}
.csh-comp-hero-matchup {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  margin-bottom: 20px;
}
.csh-comp-hero-side {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  max-width: 200px;
}
.csh-comp-hero-logo {
  width: 72px;
  height: 72px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 22px;
  color: #fff;
  box-shadow: 0 4px 12px rgba(0,0,0,.25);
}
.csh-comp-hero-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -.01em;
}
.csh-comp-hero-best {
  font-size: 13px;
  color: #94A3B8;
}
.csh-comp-hero-vs-circle {
  width: 52px;
  height: 52px;
  background: rgba(255,255,255,.08);
  border: 2px solid rgba(255,255,255,.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 800;
  color: rgba(255,255,255,.65);
  letter-spacing: .05em;
  flex-shrink: 0;
}
body:not(.home) .entry-content .csh-comp-hero-sub {
  font-size: 15px;
  color: rgba(255,255,255,.65);
  line-height: 1.6;
  max-width: 500px;
  margin: 0 auto;
}
@media (max-width: 640px) {
  .csh-comp-hero-full { padding: 32px 20px; }
  .csh-comp-hero-matchup { gap: 16px; }
  .csh-comp-hero-logo { width: 56px; height: 56px; font-size: 18px; }
  .csh-comp-hero-name { font-size: 18px; }
  .csh-comp-hero-vs-circle { width: 40px; height: 40px; font-size: 12px; }
}

/* ─── PHASE 4: STATIC PAGE HERO (full-width) ─────────────── */
.csh-page-hero-wrap {
  margin-left: calc(-50vw + 50%);
  margin-right: calc(-50vw + 50%);
  margin-bottom: 32px;
}
.csh-page-hero {
  background: #1C2B4B;
  background-image:
    radial-gradient(ellipse at 60% 0%, rgba(224,122,58,.06) 0%, transparent 50%);
  padding: 48px 40px 40px;
  text-align: center;
}
.csh-page-hero-inner {
  max-width: 700px;
  margin: 0 auto;
}
.csh-ph-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  color: #E07A3A;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.csh-ph-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: #fff;
  line-height: 1.1;
  margin: 0 0 12px;
  letter-spacing: -.01em;
  text-transform: none;
}
body:not(.home) .entry-content .csh-ph-subtitle {
  font-size: 15px;
  color: rgba(255,255,255,.65);
  line-height: 1.65;
  max-width: 560px;
  margin: 0 auto;
}
@media (max-width: 640px) {
  .csh-page-hero { padding: 32px 20px; }
  .csh-ph-title { font-size: 28px; }
}

/* ─── PHASE 2F: ARTICLE BODY STYLING ─────────────────────── */
/* Inline disclosure callout styling */
body.single-post .entry-content p[style*="border-left:4px solid #e67e22"] {
  border-radius: 0 8px 8px 0 !important;
  font-family: 'Barlow', sans-serif !important;
}

/* Style tables in article content */
body:not(.home) .entry-content table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
  margin-bottom: 20px;
}
body:not(.home) .entry-content table th {
  background: #1C2B4B;
  color: #fff;
  padding: 11px 14px;
  text-align: left;
  font-size: 13px;
  font-weight: 700;
}
body:not(.home) .entry-content table td {
  padding: 10px 14px;
  border-bottom: 1px solid #e4e6ea;
}
body:not(.home) .entry-content table tr:nth-child(even) td {
  background: #f8f9fa;
}

/* ─── KADENCE OVERRIDES FOR INNER PAGES ──────────────────── */
/* Remove excess spacing Kadence adds */
body.single-post .site-main { padding-top: 0 !important; }
body.single-post .entry-header { margin-bottom: 0 !important; }

/* Ensure pages also clean up */
body.page:not(.home) .entry-header .entry-title.entry-title { display: block; }
body.page-id-129 .entry-header,
body.page-id-121 .entry-header,
body.page-id-120 .entry-header,
body.page-id-17 .entry-header,
body.page-id-19 .entry-header,
body.page-id-130 .entry-header {
  margin-bottom: 0 !important;
  padding: 0 !important;
}

/* ─── PHASE 2D: DIMENSION SCORE BARS ────────────────────── */
.csh-dim-scores {
  margin-bottom: 28px;
}
.csh-dim-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #1C2B4B;
  border-bottom: 2px solid #E2E8F0;
  padding-bottom: 8px;
  margin: 0 0 16px;
}
.csh-dim-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}
.csh-dim-name {
  font-size: 14px;
  font-weight: 600;
  color: #1C2B4B;
  width: 160px;
  flex-shrink: 0;
}
.csh-dim-bar-wrap {
  flex: 1;
  background: #E2E8F0;
  border-radius: 4px;
  height: 8px;
  overflow: hidden;
}
.csh-dim-bar {
  height: 8px;
  border-radius: 4px;
  background: #1C2B4B;
}
.csh-dim-tier {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  width: 80px;
  text-align: right;
  flex-shrink: 0;
}
.csh-dt-excellent { color: #065F46; }
.csh-dt-good      { color: #1E40AF; }
.csh-dt-adequate  { color: #92400E; }
.csh-dt-limited   { color: #991B1B; }
@media (max-width: 480px) {
  .csh-dim-name { width: 110px; font-size: 13px; }
  .csh-dim-tier { width: 64px; font-size: 10px; }
}

/* ─── PHASE 2E: ARTICLE SIDEBAR ─────────────────────────── */
/* 2-col grid layout when sidebar is present */
.single .entry-content:has(.csh-sidebar) {
  display: grid;
  grid-template-columns: 1fr 260px;
  column-gap: 40px;
  align-items: start;
}
.single .entry-content:has(.csh-sidebar) > * {
  grid-column: 1;
}
/* Hero spans full grid width at row 1 so calc(50% - 50vw) resolves against container, not cell */
.single .entry-content:has(.csh-sidebar) > .csh-review-hero-wrap {
  grid-column: 1 / -1;
  grid-row: 1;
}
/* Sidebar occupies col 2, spanning from row 2 downward, sticky */
.single .entry-content:has(.csh-sidebar) > .csh-sidebar {
  grid-column: 2;
  grid-row: 2 / span 100;
  align-self: start;
  position: sticky;
  top: 100px;
}
/* Sidebar widget card */
.csh-sw {
  background: #F8FAFC;
  border: 1px solid #E2E8F0;
  border-radius: 10px;
  padding: 16px 18px;
  margin-bottom: 18px;
}
.csh-sw-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #64748B;
  margin: 0 0 10px;
  padding-bottom: 8px;
  border-bottom: 1px solid #E2E8F0;
}
/* Table of Contents */
.csh-toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.csh-toc-list li {
  border-bottom: 1px solid #F1F5F9;
}
.csh-toc-list li:last-child { border-bottom: none; }
.csh-toc-link {
  display: block;
  padding: 5px 0;
  font-size: 13px;
  color: #1C2B4B !important;
  text-decoration: none !important;
  line-height: 1.4;
  transition: color .15s;
}
.csh-toc-link:hover { color: #E07A3A !important; }
/* Quick facts */
.csh-qf-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.csh-qf-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 0;
  font-size: 13px;
  color: #475569;
  border-bottom: 1px solid #F1F5F9;
}
.csh-qf-row:last-child { border-bottom: none; }
.csh-qf-row strong { color: #1C2B4B; font-weight: 700; }
/* Also consider alt cards */
.csh-alt-card {
  border: 1px solid #E2E8F0;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.csh-alt-card:last-child { margin-bottom: 0; }
.csh-alt-name {
  font-weight: 700;
  font-size: 14px;
  color: #1C2B4B;
  margin-bottom: 2px;
}
.csh-alt-reason {
  font-size: 12px;
  color: #64748B;
  margin-bottom: 5px;
  line-height: 1.4;
}
.csh-alt-link {
  font-size: 12px;
  font-weight: 600;
  color: #E07A3A !important;
  text-decoration: none !important;
}
.csh-alt-link:hover { color: #c96928 !important; }
@media (max-width: 960px) {
  .single .entry-content:has(.csh-sidebar) {
    display: block;
  }
  .csh-sidebar {
    margin-top: 36px;
  }
}

/* ─── PHASE 3B/C: COMPARISON ELEMENTS ───────────────────── */
/* Winner banner */
.csh-winner-banner {
  background: #D1FAE5;
  border: 1px solid #6EE7B7;
  border-radius: 8px;
  padding: 14px 20px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 28px;
}
.csh-winner-badge {
  background: #065F46;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 6px;
  flex-shrink: 0;
  margin-top: 2px;
}
.csh-winner-text {
  font-size: 14px;
  font-weight: 700;
  color: #065F46;
  margin-bottom: 3px;
}
.csh-winner-caveat {
  font-size: 13px;
  color: #047857;
}
/* At-a-glance table */
.csh-glance-wrap { margin-bottom: 36px; }
.csh-glance-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #1C2B4B;
  border-bottom: 2px solid #E2E8F0;
  padding-bottom: 8px;
  margin: 0 0 16px;
}
.csh-glance-table {
  width: 100%;
  border-collapse: collapse;
  overflow: hidden;
  border: 1px solid #E2E8F0;
  font-size: 14px;
}
.csh-glance-table th {
  background: #1C2B4B;
  color: #fff;
  padding: 12px 14px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  text-align: center;
}
.csh-glance-table th:first-child {
  background: #14213A;
  text-align: left;
  width: 150px;
}
.csh-glance-table td {
  padding: 10px 14px;
  text-align: center;
  color: #374151;
  border-bottom: 1px solid #F1F5F9;
}
.csh-glance-table td:first-child {
  font-weight: 600;
  color: #64748B;
  background: #F8FAFC;
  text-align: left;
}
.csh-glance-table tr:nth-child(even) td:not(:first-child) { background: #F8FAFC; }
.csh-glance-table td.csh-winner-cell { font-weight: 700; color: #065F46; }
/* Comparison dimension bars */
.csh-comp-dims { margin-bottom: 36px; }
.csh-comp-dims-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #1C2B4B;
  border-bottom: 2px solid #E2E8F0;
  padding-bottom: 8px;
  margin: 0;
}
.csh-comp-dims-header {
  display: grid;
  grid-template-columns: 140px 1fr 24px 1fr;
  gap: 12px;
  padding: 10px 0 8px;
  border-bottom: 1px solid #E2E8F0;
}
.csh-comp-dims-header-a {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 800;
  color: #1C2B4B;
  letter-spacing: .5px;
  text-transform: uppercase;
  text-align: center;
}
.csh-comp-dims-header-b {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  font-weight: 800;
  color: #E07A3A;
  letter-spacing: .5px;
  text-transform: uppercase;
  text-align: center;
}
.csh-comp-dim-row {
  display: grid;
  grid-template-columns: 140px 1fr 24px 1fr;
  gap: 12px;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #F1F5F9;
}
.csh-comp-dim-row:last-child { border-bottom: none; }
.csh-comp-dim-label {
  font-size: 13px;
  font-weight: 600;
  color: #475569;
}
.csh-comp-dim-bars {
  display: flex;
  align-items: center;
  gap: 8px;
}
.csh-comp-dim-bar-wrap {
  flex: 1;
  background: #E2E8F0;
  border-radius: 4px;
  height: 8px;
  overflow: hidden;
}
.csh-comp-bar-a { height: 8px; border-radius: 4px; background: #1C2B4B; }
.csh-comp-bar-b { height: 8px; border-radius: 4px; background: #E07A3A; }
.csh-comp-dim-tier {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .5px;
  text-transform: uppercase;
  width: 64px;
  text-align: right;
  flex-shrink: 0;
}
.csh-comp-dim-sep {
  text-align: center;
  font-size: 12px;
  color: #CBD5E1;
  font-weight: 700;
}
/* Verdict boxes */
.csh-verdict-boxes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 32px;
}
.csh-vbox { border-radius: 10px; padding: 20px; }
.csh-vbox-green { background: #F0FDF4; border: 1px solid #BBF7D0; }
.csh-vbox-orange { background: #FFF7ED; border: 1px solid #FED7AA; }
.csh-vbox h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
  margin: 0 0 10px;
}
.csh-vbox-green h4 { color: #065F46; }
.csh-vbox-orange h4 { color: #9A3412; }
.csh-vbox ul { list-style: none; padding: 0; margin: 0; }
.csh-vbox li {
  font-size: 14px;
  color: #374151;
  padding: 4px 0 4px 18px;
  position: relative;
  line-height: 1.4;
}
.csh-vbox-green li::before { content: "✓"; position: absolute; left: 0; color: #059669; font-weight: 700; }
.csh-vbox-orange li::before { content: "✓"; position: absolute; left: 0; color: #EA580C; font-weight: 700; }
/* Dual CTA row */
.csh-cta-row {
 display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 32px;
}
.csh-cta-box {
  border: 1px solid #E2E8F0;
  border-radius: 10px;
  padding: 20px;
  text-align: center;
}
.csh-cta-box h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px;
  font-weight: 800;
  color: #1C2B4B;
  margin: 0 0 6px;
}
.csh-cta-box p {
  font-size: 13px;
  color: #64748B;
  margin: 0 0 14px;
}
.csh-cta-btn-primary {
  display: inline-block;
  background: #E07A3A;
  color: #fff !important;
  padding: 10px 22px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none !important;
  transition: background .2s;
}
.csh-cta-btn-primary:hover { background: #c96928; }
.csh-cta-btn-secondary {
  display: inline-block;
  background: #1C2B4B;
  color: #fff !important;
  padding: 10px 22px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none !important;
  transition: background .2s;
}
.csh-cta-btn-secondary:hover { background: #111d33; }
@media (max-width: 640px) {
  .csh-verdict-boxes,
  .csh-cta-row { grid-template-columns: 1fr; }
  .csh-comp-dims-header,
  .csh-comp-dim-row { grid-template-columns: 100px 1fr 16px 1fr; gap: 8px; }
  .csh-comp-dim-label { font-size: 12px; }
  .csh-comp-dim-tier { width: 54px; }
}


/* =============================================
   PHASE 4: STATIC PAGE CONTENT
   ============================================= */

/* Trust Bar */
.csh-trust-bar {
  background: #F8FAFC;
  border: 1px solid #E2E8F0;
  border-radius: 10px;
  padding: 24px 20px;
  margin-bottom: 40px;
}
.csh-trust-bar-inner {
  display: flex;
  gap: 32px;
  justify-content: center;
  flex-wrap: wrap;
}
.csh-trust-item { text-align: center; }
.csh-trust-number {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 32px;
  font-weight: 800;
  color: #E07A3A;
}
.csh-trust-label {
  font-size: 13px;
  color: #64748B;
  margin-top: 2px;
}

/* Editorial Independence Pledge */
/* Override global entry-content h2 rule (higher specificity) */
body:not(.home) .entry-content .csh-pledge-box h2 {
  color: #fff;
  border-bottom: none;
  padding-bottom: 0;
  margin: 0 0 12px;
}
.csh-pledge-box {
  background: #1C2B4B;
  border-radius: 12px;
  padding: 32px;
  margin-bottom: 40px;
  text-align: center;
}
.csh-pledge-box h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 800;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 12px;
}
body:not(.home) .entry-content .csh-pledge-box p {
  color: #CBD5E1;
  font-size: 15px;
  line-height: 1.7;
  max-width: 560px;
  margin: 0 auto 10px;
}
.csh-pledge-box a { color: #E07A3A; font-weight: 600; }

/* Process Steps */
.csh-process-steps { margin-bottom: 40px; }
.csh-process-steps h2,
.csh-verdict-system h2,
.csh-dim-table h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 24px;
  font-weight: 800;
  text-transform: uppercase;
  color: #1C2B4B;
  margin-bottom: 20px;
  border-bottom: 2px solid #E2E8F0;
  padding-bottom: 10px;
}
.csh-step {
  display: flex;
  gap: 18px;
  margin-bottom: 22px;
  align-items: flex-start;
}
.csh-step-number {
  width: 40px;
  height: 40px;
  background: #1C2B4B;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px;
  font-weight: 800;
  flex-shrink: 0;
  margin-top: 2px;
}
.csh-step-content h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 17px;
  font-weight: 800;
  text-transform: uppercase;
  color: #1C2B4B;
  margin-bottom: 4px;
}
.csh-step-content p {
  font-size: 15px;
  line-height: 1.7;
  color: #374151;
}

/* Verdict System */
.csh-verdict-system { margin-bottom: 40px; }
.csh-verdict-intro {
  font-size: 15px;
  color: #374151;
  line-height: 1.7;
  margin-bottom: 20px;
}
.csh-verdict-tiers {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 16px;
}
@media (max-width: 580px) {
  .csh-verdict-tiers { grid-template-columns: 1fr; }
}
.csh-vt-card {
  border-radius: 10px;
  padding: 16px;
  border: 1px solid;
}
.csh-vt-card.top { background: #F0FDF4; border-color: #BBF7D0; }
.csh-vt-card.strong { background: #EFF6FF; border-color: #BFDBFE; }
.csh-vt-card.specialist { background: #FFFBEB; border-color: #FDE68A; }
.csh-vt-card.skip { background: #FEF2F2; border-color: #FECACA; }
.csh-vt-badge {
  display: inline-block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
  margin-bottom: 8px;
}
.csh-vt-badge.top { background: #D1FAE5; color: #065F46; }
.csh-vt-badge.strong { background: #DBEAFE; color: #1E40AF; }
.csh-vt-badge.specialist { background: #FEF3C7; color: #92400E; }
.csh-vt-badge.skip { background: #FEE2E2; color: #991B1B; }
.csh-vt-desc { font-size: 14px; color: #475569; line-height: 1.5; }
.csh-numeric-note {
  background: #FFF7ED;
  border: 1px solid #FED7AA;
  border-radius: 8px;
  padding: 16px 18px;
  font-size: 14px;
  color: #9A3412;
  line-height: 1.6;
}
.csh-numeric-note strong {
  display: block;
  margin-bottom: 4px;
  font-size: 15px;
}

/* Dimension Table */
.csh-dim-table { margin-bottom: 40px; }
.csh-dim-table table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.csh-dim-table thead tr { background: #1C2B4B; }
.csh-dim-table thead th {
  color: #fff;
  padding: 10px 14px;
  text-align: left;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.csh-dim-table tbody tr:nth-child(even) { background: #F8FAFC; }
.csh-dim-table tbody td {
  padding: 10px 14px;
  color: #374151;
  border-bottom: 1px solid #F1F5F9;
  vertical-align: top;
  font-size: 13px;
}
.csh-dim-table tbody td:first-child {
  font-weight: 700;
  color: #1C2B4B;
}
@media (max-width: 600px) {
  .csh-dim-table table,
  .csh-dim-table thead,
  .csh-dim-table tbody,
  .csh-dim-table th,
  .csh-dim-table td,
  .csh-dim-table tr { display: block; }
  .csh-dim-table thead tr { display: none; }
  .csh-dim-table tbody td { padding: 6px 10px; }
  .csh-dim-table tbody td:first-child { background: #F1F5F9; font-size: 14px; }
}

/* Contact Box */
.csh-contact-box {
  background: #F8FAFC;
  border: 1px solid #E2E8F0;
  border-radius: 12px;
  padding: 32px;
  margin: 24px 0 32px;
  text-align: center;
}
.csh-contact-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #64748B;
  margin-bottom: 8px;
}
.csh-contact-email {
  display: inline-block;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px;
  font-weight: 800;
  text-decoration: none;
  margin-bottom: 12px;
  padding: 10px 24px;
  background: #1C2B4B;
  color: #fff;
  border-radius: 6px;
}
.csh-contact-email:hover { background: #E07A3A; color: #fff; }
.csh-contact-note {
  font-size: 13px;
  color: #64748B;
  margin-top: 12px;
  margin-bottom: 0;
}

/* Suppress Kadence default footer — CSH branded footer replaces it on inner pages */
#colophon {
  display: none !important;
}


/* Mobile CTA bar: FTC "Affiliate link" disclosure via ::before */
.csh-mobile-cta::before {
  content: "Affiliate link";
  display: block;
  font-size: 9px;
  font-weight: 500;
  color: rgba(255,255,255,0.5);
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding-top: 6px;
  margin-bottom: 2px;
}</style><link rel="icon" href="https://contractorsoftwarehub.com/wp-content/uploads/2026/02/contractorsoftwarehub-icon-150x150.png" sizes="32x32" />
