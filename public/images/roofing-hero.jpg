<style class="wpcode-css-snippet">/* ============================================================
   Hub Page — /best-contractor-software/ (Phase 3)
   Scoped to .page-id-41 to avoid conflicts
   ============================================================ */

/* Base */
.page-id-41 .csh-hub-wrap {
  font-family: inherit;
  color: #ffffff;
}
.page-id-41 .csh-hub-wrap *,
.page-id-41 .csh-hub-wrap *::before,
.page-id-41 .csh-hub-wrap *::after {
  box-sizing: border-box;
}

/* ── Section 1: Hero ── */
.page-id-41 .csh-hub-hero {
  background: #1a1f2e;
  padding: 72px 24px 64px;
  text-align: center;
}
.page-id-41 .csh-hub-hero h1 {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 16px;
  line-height: 1.2;
}
.page-id-41 .csh-hub-hero .csh-hero-sub {
  font-size: 1.05rem;
  color: #b0bac9;
  margin: 0 0 24px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}
.page-id-41 .csh-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: 32px;
}
.page-id-41 .csh-chip {
  background: #252b3b;
  border: 1px solid #e67e22;
  border-radius: 50px;
  padding: 6px 14px;
  font-size: 0.8rem;
  color: #ffffff;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
  white-space: nowrap;
}
.page-id-41 .csh-chip:hover {
  background: #e67e22;
  color: #ffffff;
}
.page-id-41 .csh-btn-primary {
  display: inline-block;
  background: #e67e22;
  color: #ffffff;
  font-size: 1rem;
  font-weight: 700;
  padding: 14px 32px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
}
.page-id-41 .csh-btn-primary:hover {
  background: #cf6d17;
  color: #ffffff;
}

/* ── Section 2: By Trade + By Category ── */
.page-id-41 .csh-hub-paths {
  background: #252b3b;
  padding: 56px 24px;
}
.page-id-41 .csh-hub-paths h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 8px;
}
.page-id-41 .csh-hub-paths .csh-section-sub {
  color: #b0bac9;
  font-size: 0.95rem;
  margin: 0 0 28px;
}
.page-id-41 .csh-trade-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
  margin-bottom: 48px;
}
.page-id-41 .csh-trade-card {
  background: #1a1f2e;
  border: 1px solid #3a4155;
  border-radius: 8px;
  padding: 16px 12px;
  text-align: center;
  text-decoration: none;
  color: #ffffff;
  transition: border-color 0.2s, transform 0.15s;
}
.page-id-41 .csh-trade-card:hover {
  border-color: #e67e22;
  transform: translateY(-2px);
  color: #ffffff;
}
.page-id-41 .csh-trade-card .csh-trade-icon {
  font-size: 1.75rem;
  display: block;
  margin-bottom: 8px;
}
.page-id-41 .csh-trade-card .csh-trade-label {
  font-size: 0.82rem;
  color: #b0bac9;
  line-height: 1.3;
}
.page-id-41 .csh-category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.page-id-41 .csh-cat-card {
  background: #1a1f2e;
  border: 1px solid #3a4155;
  border-left: 3px solid #e67e22;
  border-radius: 8px;
  padding: 16px 18px;
  text-decoration: none;
  color: #ffffff;
  transition: border-color 0.2s, background 0.2s;
}
.page-id-41 .csh-cat-card:hover {
  background: #252b3b;
  color: #ffffff;
}
.page-id-41 .csh-cat-card strong {
  display: block;
  font-size: 0.95rem;
  margin-bottom: 4px;
}
.page-id-41 .csh-cat-card .csh-cat-icon {
  font-size: 1.5rem;
  display: block;
  margin-bottom: 6px;
}
.page-id-41 .csh-cat-card .csh-cat-sub {
  font-size: 0.82rem;
  color: #b0bac9;
  display: block;
}

/* ── Section 3: Top Pick ── */
.page-id-41 .csh-hub-toppick {
  background: #1a1f2e;
  padding: 56px 24px;
}
.page-id-41 .csh-hub-toppick h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 24px;
  text-align: center;
}
.page-id-41 .csh-toppick-card {
  background: #252b3b;
  border: 2px solid #e67e22;
  border-radius: 12px;
  max-width: 760px;
  margin: 0 auto;
  overflow: hidden;
}
.page-id-41 .csh-toppick-head {
  background: #1a1f2e;
  padding: 20px 28px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.page-id-41 .csh-toppick-badge {
  background: #e67e22;
  color: #ffffff;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 4px 10px;
  border-radius: 4px;
  white-space: nowrap;
}
.page-id-41 .csh-toppick-name {
  font-size: 1.2rem;
  font-weight: 700;
  color: #ffffff;
}
.page-id-41 .csh-toppick-body {
  padding: 24px 28px;
  display: flex;
  gap: 28px;
  align-items: flex-start;
}
.page-id-41 .csh-toppick-desc {
  flex: 1;
  color: #b0bac9;
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}
.page-id-41 .csh-toppick-cta {
  display: inline-block;
  background: #e67e22;
  color: #ffffff;
  font-weight: 700;
  font-size: 0.95rem;
  padding: 12px 24px;
  border-radius: 6px;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.2s;
}
.page-id-41 .csh-toppick-cta:hover {
  background: #cf6d17;
  color: #ffffff;
}

/* ── Section 4: Tool Cards (Tabbed) ── */
.page-id-41 .csh-hub-tools {
  background: #252b3b;
  padding: 56px 24px;
}
.page-id-41 .csh-hub-tools h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 28px;
}
.page-id-41 .csh-tab-bar {
  display: flex;
  gap: 0;
  border-bottom: 2px solid #3a4155;
  margin-bottom: 28px;
  flex-wrap: wrap;
}
.page-id-41 .csh-tab {
  padding: 10px 20px;
  font-size: 0.9rem;
  font-weight: 600;
  color: #b0bac9;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  transition: color 0.2s, border-color 0.2s;
  background: none;
  border-top: none;
  border-left: none;
  border-right: none;
  text-decoration: none;
}
.page-id-41 .csh-tab:hover,
.page-id-41 .csh-tab.is-active {
  color: #ffffff;
  border-bottom-color: #e67e22;
}
.page-id-41 .csh-panel {
  display: none;
}
.page-id-41 .csh-panel.is-active {
  display: block;
}
.page-id-41 .csh-card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.page-id-41 .csh-tool-card {
  background: #1a1f2e;
  border: 1px solid #3a4155;
  border-radius: 8px;
  padding: 20px;
  text-decoration: none;
  color: #ffffff;
  display: block;
  transition: border-color 0.2s, transform 0.15s;
}
.page-id-41 .csh-tool-card:hover {
  border-color: #e67e22;
  transform: translateY(-2px);
  color: #ffffff;
}
.page-id-41 .csh-tool-card strong {
  display: block;
  font-size: 1rem;
  margin-bottom: 6px;
}
.page-id-41 .csh-tool-card span {
  font-size: 0.83rem;
  color: #b0bac9;
  line-height: 1.4;
}

/* ── Section 5: Comparisons ── */
.page-id-41 .csh-hub-comps {
  background: #1a1f2e;
  padding: 56px 24px;
}
.page-id-41 .csh-hub-comps h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 24px;
}
.page-id-41 .csh-comp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.page-id-41 .csh-comp-card {
  background: #252b3b;
  border: 1px solid #3a4155;
  border-left: 3px solid #e67e22;
  border-radius: 8px;
  padding: 20px;
  text-decoration: none;
  color: #ffffff;
  display: block;
  transition: background 0.2s, transform 0.15s;
}
.page-id-41 .csh-comp-card:hover {
  background: #2e3650;
  transform: translateY(-2px);
  color: #ffffff;
}
.page-id-41 .csh-comp-card strong {
  display: block;
  font-size: 0.95rem;
  margin-bottom: 6px;
}
.page-id-41 .csh-comp-card span {
  font-size: 0.83rem;
  color: #b0bac9;
  line-height: 1.4;
}

/* ── Section 6: Trust & Methodology ── */
.page-id-41 .csh-hub-trust {
  background: #252b3b;
  padding: 48px 24px;
}
.page-id-41 .csh-hub-trust h2 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 24px;
}
.page-id-41 .csh-trust-row {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.page-id-41 .csh-trust-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  flex: 1;
  min-width: 180px;
}
.page-id-41 .csh-trust-icon {
  font-size: 2rem;
  color: #e67e22;
  flex-shrink: 0;
  line-height: 1;
}
.page-id-41 .csh-trust-item strong {
  display: block;
  font-size: 0.9rem;
  color: #ffffff;
  margin-bottom: 4px;
}
.page-id-41 .csh-trust-item p {
  font-size: 0.83rem;
  color: #b0bac9;
  margin: 0;
  line-height: 1.4;
}
.page-id-41 .csh-trust-divider {
  border: none;
  border-top: 1px solid #3a4155;
  margin: 0 0 20px;
}
.page-id-41 .csh-methodology-link {
  color: #e67e22;
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
}
.page-id-41 .csh-methodology-link:hover {
  text-decoration: underline;
}

/* ── Section 7: Footer CTA ── */
.page-id-41 .csh-hub-fcta {
  background: #e67e22;
  padding: 48px 24px;
  text-align: center;
}
.page-id-41 .csh-hub-fcta h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 8px;
}
.page-id-41 .csh-hub-fcta p {
  color: rgba(255,255,255,0.85);
  font-size: 1rem;
  margin: 0 0 24px;
}
.page-id-41 .csh-btn-white {
  display: inline-block;
  background: #ffffff;
  color: #e67e22;
  font-weight: 700;
  font-size: 1rem;
  padding: 14px 32px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.page-id-41 .csh-btn-white:hover {
  background: #f5f5f5;
  color: #e67e22;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .page-id-41 .csh-trade-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (max-width: 768px) {
  .page-id-41 .csh-trade-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .page-id-41 .csh-category-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .page-id-41 .csh-toppick-body {
    flex-direction: column;
  }
  .page-id-41 .csh-toppick-cta {
    width: 100%;
    text-align: center;
  }
  .page-id-41 .csh-card-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .page-id-41 .csh-comp-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .page-id-41 .csh-trust-row {
    flex-direction: column;
    gap: 20px;
  }
}
@media (max-width: 480px) {
  .page-id-41 .csh-hub-hero {
    padding: 48px 16px 40px;
  }
  .page-id-41 .csh-trade-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .page-id-41 .csh-category-grid {
    grid-template-columns: 1fr;
  }
  .page-id-41 .csh-card-grid {
    grid-template-columns: 1fr;
  }
  .page-id-41 .csh-comp-grid {
    grid-template-columns: 1fr;
  }
  .page-id-41 .csh-tab {
    padding: 8px 12px;
    font-size: 0.82rem;
  }
}

/* ── Hidden panels (tab system) ── */
.page-id-41 .csh-hidden {
  display: none !important;
}

/* ── Section headings (override Kadence link color on h2) ── */
.page-id-41 .csh-hub-paths h2,
.page-id-41 .csh-hub-tools h2,
.page-id-41 .csh-hub-comps h2,
.page-id-41 .csh-hub-trust h2,
.page-id-41 .csh-hub-h2-light {
  color: #ffffff !important;
}

/* ── Card inner elements (override Kadence link color) ── */
.page-id-41 .csh-tool-card,
.page-id-41 .csh-comp-card,
.page-id-41 .csh-cat-card,
.page-id-41 .csh-trade-card {
  color: #ffffff !important;
}
.page-id-41 .csh-tool-card:hover,
.page-id-41 .csh-comp-card:hover,
.page-id-41 .csh-cat-card:hover,
.page-id-41 .csh-trade-card:hover {
  color: #ffffff !important;
}
.page-id-41 .csh-card-badge {
  background: #e67e22;
  color: #ffffff;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 3px 8px;
  border-radius: 3px;
  margin-bottom: 4px;
  display: inline-block;
}
.page-id-41 .csh-card-score {
  font-size: 1.4rem;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  margin-bottom: 2px;
}
.page-id-41 .csh-card-name {
  font-size: 1rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6px;
}
.page-id-41 .csh-card-desc {
  font-size: 0.83rem;
  color: #b0bac9;
  line-height: 1.4;
  margin-bottom: 10px;
}
.page-id-41 .csh-card-cta,
.page-id-41 .csh-card-review {
  display: inline-block;
  font-size: 0.82rem;
  color: #e67e22;
  text-decoration: none;
  margin-right: 12px;
}
.page-id-41 .csh-card-cta:hover,
.page-id-41 .csh-card-review:hover {
  text-decoration: underline;
  color: #cf6d17;
}

/* ── Comparison List (actual HTML uses .csh-comp-list not .csh-comp-grid) ── */
.page-id-41 .csh-comp-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.page-id-41 .csh-comp-link {
  display: inline-block;
  color: #e67e22 !important;
  font-size: 0.82rem;
  font-weight: 600;
  text-decoration: none;
  margin-top: 10px;
}
.page-id-41 .csh-comp-link:hover {
  text-decoration: underline;
  color: #cf6d17 !important;
}
.page-id-41 .csh-hub-h2 {
  color: #ffffff !important;
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 8px;
}
.page-id-41 .csh-hub-sub {
  color: #b0bac9;
  font-size: 0.95rem;
  margin: 0 0 24px;
}
/* Override Kadence link blue on all hub-wrap links */
.page-id-41 .csh-hub-wrap a {
  color: inherit;
}
/* Comp card inner div (title) */
.page-id-41 .csh-comp-card > div {
  color: #ffffff;
}
@media (max-width: 768px) {
  .page-id-41 .csh-comp-list {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 480px) {
  .page-id-41 .csh-comp-list {
    grid-template-columns: 1fr;
  }
}

/* === Patch 4: Footer CTA, Comp Titles, Category Display === */

/* Footer CTA text colors */
.page-id-41 .csh-hub-fcta-title { color: #ffffff !important; font-size: 1.5rem; font-weight: 700; margin: 0 0 8px; }
.page-id-41 .csh-hub-fcta-sub { color: rgba(255,255,255,0.9) !important; margin: 0 0 24px; }
.page-id-41 .csh-hub-fcta-fine { color: rgba(255,255,255,0.75) !important; font-size: 0.85rem; margin-top: 8px; }
.page-id-41 .csh-hub-fcta-btn { color: #e67e22 !important; background: #ffffff !important; font-weight: 700; font-size: 1rem; padding: 14px 32px; border-radius: 6px; text-decoration: none; display: inline-block; }
.page-id-41 .csh-hub-fcta-btn:hover { background: #f5f5f5 !important; color: #e67e22 !important; }

/* Comparison card title/sub colors */
.page-id-41 .csh-comp-title { color: #ffffff !important; font-size: 1rem; font-weight: 700; margin: 0 0 6px; }
.page-id-41 .csh-comp-sub { color: rgba(255,255,255,0.7) !important; font-size: 0.875rem; margin: 0; }

/* Category grid — name/sub as block elements */
.page-id-41 .csh-category-name { display: block !important; font-weight: 700; font-size: 1rem; }
.page-id-41 .csh-category-sub { display: block !important; font-size: 0.8rem; opacity: 0.75; }


/* === Patch 6: Section backgrounds — match site blue #1C2B4B === */
.page-id-41 .csh-hub-hero,
.page-id-41 .csh-hub-toppick,
.page-id-41 .csh-hub-comps { background-color: #1C2B4B !important; }

.page-id-41 .csh-hub-paths,
.page-id-41 .csh-hub-tools,
.page-id-41 .csh-hub-trust { background-color: #1e3461 !important; }

/* === Patch 6: Dark font fixes — all leaf elements === */
.page-id-41 .csh-hub-hero__sub { color: rgba(255,255,255,0.85) !important; }
.page-id-41 .csh-toppick-name { color: #ffffff !important; }
.page-id-41 .csh-toppick-desc { color: rgba(255,255,255,0.85) !important; }
.page-id-41 .csh-toppick-body li { color: rgba(255,255,255,0.85) !important; }
.page-id-41 .csh-toppick-fine { color: rgba(255,255,255,0.6) !important; }
.page-id-41 .csh-hub-sub { color: rgba(255,255,255,0.75) !important; }
.page-id-41 .csh-trust-link { color: rgba(255,255,255,0.8) !important; }


/* === Patch 7: Site-wide consistency fixes 2026-03-11 === */

/* U1: Hub H1 — add Barlow Condensed (existing rule had font-size/weight but not font-family) */
.page-id-41 .csh-hub-hero h1 {
  font-family: 'Barlow Condensed', sans-serif !important;
}

/* U2: HVAC roundup eyebrow — fix dark gray to orange (near-invisible on navy) */
.csh-review-hero .csh-rh-category {
  color: rgb(224, 122, 58) !important;
}

/* U3: Remove text-transform uppercase from comparison + How We Review heroes */
.csh-comp-hero h1,
.csh-page-hero h1 {
  text-transform: none !important;
}

/* U4: Unify primary/secondary CTA button border-radius to 8px */
.csh-cta-btn-primary,
.csh-cta-btn-secondary {
  border-radius: 8px !important;
}

/* U6: Standardize affiliate disclosure bar */
.csh-affiliate-disclosure {
  background: rgb(255, 251, 235) !important;
  border-left: 3px solid rgb(224, 122, 58) !important;
  padding: 12px 16px !important;
  font-size: 14px !important;
  color: rgb(45, 55, 72) !important;
  border-radius: 4px !important;
  margin-bottom: 24px !important;
  display: block !important;
}
</style><style class="wpcode-css-snippet">/* Fix: body.single-post rules hide thumbnail + entry-header globally,
   breaking the Kadence Related Posts carousel cards.
   These overrides restore visibility within .entry-related only. */

body.single-post .entry-related article .post-thumbnail,
body.single-post .entry-related article .entry-thumbnail,
body.single-post .entry-related article .kadence-entry-thumbnail,
body.single-post .entry-related article .wp-post-image-wrap {
  display: block !important;
}

body.single-post .entry-related article .entry-header {
  display: block !important;
}

body.single-post .entry-related article .entry-header .entry-title,
body.single-post .entry-related article .entry-header .kadence-entry-title {
