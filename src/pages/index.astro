        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-3">Compare</h3>
        <ul class="space-y-2">
          <li><a href="/blog/jobber-vs-housecall-pro/" class="hover:text-white">Jobber vs Housecall Pro</a></li>
          <li><a href="/blog/servicetitan-vs-jobber/" class="hover:text-white">ServiceTitan vs Jobber</a></li>
          <li><a href="/blog/housecall-pro-vs-fieldedge/" class="hover:text-white">Housecall Pro vs FieldEdge</a></li>
        </ul>
      </div>
      <div>
