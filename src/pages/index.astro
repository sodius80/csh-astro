---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RatingStamp from '../components/RatingStamp.astro';
import { buildCategorySummaries, getEntryDate, itemKindFromEntry, itemUrlFromEntry, sortByEntryDate } from '../lib/content';

const reviews = await getCollection('reviews');
const roundups = await getCollection('roundups');
const comparisons = await getCollection('comparisons');
const guides = await getCollection('guides');

const featured = sortByEntryDate(reviews).find((r) => r.id === 'jobber') ?? sortByEntryDate(reviews)[0];
const recent = sortByEntryDate([...reviews, ...roundups, ...comparisons, ...guides]).slice(0, 6);
const categoryCards = buildCategorySummaries(reviews, roundups, comparisons)
  .filter((card) => card.route.startsWith('/best/'))
  .slice(0, 12)
  .map((card, index) => ({
    n: String(index + 1).padStart(2, '0'),
    h: card.title,
    href: card.route,
    desc: card.description,
  }));
const quickRoutes = categoryCards.slice(0, 4);
---
<BaseLayout
  title="Contractor Software Hub — Honest software coverage for the trades"
  description="Independent software reviews, comparisons, and best-of roundups for contractors. No vendor influence — just the honest read on what works for your trade and team size."
  active="home"
>
  <!-- MASTHEAD HERO -->
  <section class="hero blueprint-bg">
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <div class="hero-eyebrow">A statement from the editor</div>
          <h1 class="display hero-title">
            Buy the<br/>
            right tool.<br/>
            <span class="accent">Once.</span>
          </h1>
          <p class="serif hero-lede">
            Most contractor software reviews are rewritten vendor copy. We read dozens of real contractor reviews per product, pull pricing from live vendor pages, and tell you who a tool is <em>wrong</em> for. No SEO fluff. No affiliate-driven rankings. Just the honest call.
          </p>
          <div class="hero-ctas">
            <a class="btn orange" href="/reviews/">Find your tool <span class="arr">→</span></a>
            <a class="btn outline" href="/reviews/jobber/">Read a review</a>
            <div class="hero-meta">
              {reviews.length} reviews · {comparisons.length} comparisons · {roundups.length} roundups · {guides.length} guides
            </div>
          </div>
        </div>

        <div class="finder-card card">
          <div class="eyebrow eyebrow-muted" style="margin-bottom:10px;">Quick routes</div>
          <div class="display" style="font-size:26px;margin-bottom:16px;line-height:1;">Start where you<br/>actually work.</div>
          <div class="finder-routes">
            {quickRoutes.map((route) => (
              <a href={route.href} class="route"><span class="n">{route.n}</span><span class="l">{route.h}</span><span class="r">View →</span></a>
            ))}
          </div>
          <a href="/finder/" class="btn" style="width:100%;justify-content:center;">
            Open finder <span class="arr">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED REVIEW -->
  {featured && (
    <section class="section">
      <div class="wrap">
        <div class="rule-label" style="margin-bottom:32px;">
          <span>Featured review</span>
          <span style="flex:1;"></span>
          <span style="color:var(--graphite);">
            Updated {(featured.data.updatedDate ?? featured.data.pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          </span>
        </div>
        <div class="featured">
          <div class="featured-img">
            {featured.data.heroImage ? (
              <img src={featured.data.heroImage} alt={featured.data.vendor} />
            ) : (
              <div class="placeholder" style="height:460px;">Hero · {featured.data.vendor}</div>
            )}
            <div class="featured-stamp">
              <RatingStamp rating={featured.data.rating} rotate={-6} />
            </div>
          </div>
          <div>
            <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
              <span class="pill ink">{featured.data.category}</span>
              {featured.data.trades.slice(0, 3).map(t => <span class="pill">{t}</span>)}
            </div>
            <h2 class="display featured-title">{featured.data.vendor} Review <span class="accent">{featured.data.updatedDate?.getFullYear() ?? 2026}</span></h2>
            <p class="serif featured-lede">{featured.data.description}</p>
            <div class="featured-meta">
              <div class="byline">
                <div style="color:var(--graphite);">By the editor</div>
                <div style="color:var(--ink);font-weight:700;margin-top:2px;">{featured.data.author}{featured.data.readTime ? ` · ${featured.data.readTime}` : ''}</div>
              </div>
              <a href={`/reviews/${featured.id}/`} class="btn">Read full review <span class="arr">→</span></a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CATEGORY MATRIX -->
  <section class="section">
    <div class="wrap">
      <div class="matrix-head">
        <div>
          <div class="eyebrow eyebrow-muted" style="margin-bottom:12px;">Browse · by category · by trade</div>
          <h2 class="display" style="font-size:clamp(40px, 5vw, 56px); line-height:0.95;">Every tool,<br/>in its place.</h2>
        </div>
        <div style="text-align:right;max-width:360px;">
          <p class="serif" style="font-size:15px;line-height:1.5;color:var(--ink-2);margin-bottom:14px;">
            One flat matrix. Every tool we've covered, sortable by trade, team size, price, or recency. No tiers, no hidden drawers, no three-click detours.
          </p>
          <a href="/reviews/" class="btn outline sm">See all reviews →</a>
        </div>
      </div>
      <div class="category-grid">
        {categoryCards.map((cat, i) => (
          <a href={cat.href} class="cat-card" style={`border-right: ${(i + 1) % 4 !== 0 ? '1px solid var(--hair)' : 'none'}; border-bottom: ${i < categoryCards.length - 4 ? '1px solid var(--hair)' : 'none'};`}>
            <div class="cat-top">
              <div class="cat-n">{cat.n}</div>
            </div>
            <div class="display cat-h">{cat.h}</div>
            <div class="cat-desc">{cat.desc}</div>
            <div class="cat-pick">
              <span class="dot"></span>View the roundup →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW WE COVER -->
  <section class="section-dark">
    <div class="wrap">
      <div class="method-grid">
        <div>
          <div class="eyebrow" style="color:var(--orange); margin-bottom:16px;">Methodology · v3.1</div>
          <h2 class="display" style="font-size:clamp(40px, 5vw, 56px); line-height:0.92; margin-bottom:20px;">
            How we<br/>actually<br/>cover things.
          </h2>
          <p class="serif" style="font-size:16px;line-height:1.55;opacity:0.8;">
            Every piece runs through the same pipeline. No exceptions for sponsors. No softening for affiliate partners. Coverage reflects what contractors actually say in aggregate — not what vendors want us to say.
          </p>
          <a href="/how-we-review/" class="btn orange" style="margin-top:24px;">Read the full method <span class="arr">→</span></a>
        </div>
        <div class="method-cells">
          {[
            { n: '01', h: 'Pull live pricing', t: "Every figure comes from the vendor's pricing page on the date of publication — never estimated or inherited from a past review." },
            { n: '02', h: 'Aggregate contractor feedback', t: 'G2 and Capterra, filtered for contractor accounts. One complaint is an anecdote. A pattern gets named.' },
            { n: '03', h: 'Check Reddit', t: 'r/Contractors, r/HVAC, r/Plumbing, r/Electricians. The complaints that never reach Capterra tend to live here.' },
            { n: '04', h: 'Name the wrong buyer', t: 'Every product has a contractor type it is wrong for. If we can\'t identify them, the research isn\'t complete.' },
            { n: '05', h: 'Verdict leads the piece', t: 'Top Pick, Recommended, Conditional, or Skip — stated before you scroll. The body explains why.' },
            { n: '06', h: 'Refresh quarterly', t: "Pricing shifts. Features ship. A timestamped note tells you when we last re-verified." },
          ].map((s, i) => (
            <div class="method-cell" style={`border-left: ${i % 2 === 1 ? '1px solid rgba(243,239,230,0.2)' : 'none'};`}>
              <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.15em;color:var(--orange);margin-bottom:10px;">{s.n}</div>
              <div class="display" style="font-size:22px;margin-bottom:10px;line-height:1;">{s.h}</div>
              <div class="serif" style="font-size:14px;line-height:1.55;opacity:0.75;">{s.t}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RECENTLY FILED -->
  {recent.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="rule-label" style="margin-bottom:36px;">
          <span>Recently filed</span>
          <span style="flex:1;"></span>
          <span style="color:var(--graphite);">Last updates</span>
        </div>
        <div class="recent-grid">
          {recent.map((item) => {
            const date = getEntryDate(item).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();
            const rating = 'rating' in item.data ? item.data.rating : null;
            const title = item.data.title;
            const heroImage = 'heroImage' in item.data ? item.data.heroImage : undefined;
            return (
              <a class="recent-card" href={itemUrlFromEntry(item)}>
                {heroImage ? (
                  <img class="recent-thumb" src={heroImage} alt={title} />
                ) : (
                  <div class="placeholder" style="height:200px;margin-bottom:18px;">{itemKindFromEntry(item)} · hero</div>
                )}
                <div class="recent-meta">
                  <span class="recent-kind">{itemKindFromEntry(item)}</span>
                  <span style="color:var(--graphite);">{date}</span>
                </div>
                <h3 class="serif recent-title">{title}</h3>
                {rating && (
                  <div style="margin-top:auto;">
                    <RatingStamp rating={rating} variant="flat" />
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- TIP LINE -->
  <section class="tipline">
    <div class="wrap tipline-grid">
      <div>
        <div class="eyebrow" style="margin-bottom:10px;">Reader tip line · no schedule, no inbox</div>
        <div class="display" style="font-size:clamp(32px, 4.4vw, 46px); line-height:0.95; margin-bottom:12px;">
          Tell us what<br/>to cover next.
        </div>
        <p class="serif" style="font-size:16px;max-width:520px;opacity:0.88;line-height:1.5;">
          No weekly email. No obligations. If there's a tool you want reviewed — or a software horror story we should dig into — send it our way. We read every one, and the most-requested tools move up our queue.
        </p>
      </div>
      <div class="tip-contact">
        <div class="eyebrow" style="margin-bottom:12px;">Send a line</div>
        <a href="mailto:info@contractorsoftwarehub.com" class="contact-email">info@contractorsoftwarehub.com</a>
        <a href="/contact/" class="btn" style="margin-top:16px;">Contact page →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .accent { color: var(--orange); }

  .hero {
    padding: 56px 28px 48px;
    border-bottom: 1.5px solid var(--ink);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    gap: 64px;
    align-items: end;
  }
  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--orange-deep);
    margin-bottom: 20px;
    font-weight: 500;
  }
  .hero-title {
    font-size: clamp(56px, 7.8vw, 112px);
    line-height: 0.88;
    margin: 0 0 28px;
    letter-spacing: -0.015em;
  }
  .hero-lede {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.4;
    max-width: 640px;
    color: var(--ink-2);
    margin: 0 0 32px;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-meta {
    margin-left: 14px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--graphite);
  }

  .finder-card { padding: 28px; }
  .finder-routes {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }
  .route {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border: 1.5px solid var(--ink);
    background: var(--paper-deep);
    text-decoration: none;
    color: var(--ink);
    transition: all 0.12s;
  }
  .route:hover { background: var(--ink); color: var(--paper); }
  .route .n {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    background: var(--ink);
    color: var(--paper);
    text-align: center;
    padding: 3px 0;
  }
  .route:hover .n { background: var(--orange); color: var(--ink); }
  .route .l { font-weight: 600; font-size: 14px; }
  .route .r {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section {
    padding: 72px 28px;
    border-bottom: 1.5px solid var(--ink);
  }
  .section-dark {
    padding: 72px 28px;
    border-bottom: 1.5px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
  }

  .featured {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .featured-img { position: relative; }
  .featured-img img {
    width: 100%;
    height: auto;
    border: 1.5px solid var(--ink);
    aspect-ratio: 16/10;
    object-fit: cover;
  }
  .featured-stamp {
    position: absolute;
    bottom: -18px;
    right: -18px;
  }
  .featured-title {
    font-size: clamp(44px, 6.2vw, 72px);
    line-height: 0.9;
    margin: 0 0 22px;
    letter-spacing: -0.01em;
  }
  .featured-lede {
    font-size: clamp(17px, 1.7vw, 19px);
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 24px;
  }
  .featured-meta {
    display: flex;
    align-items: center;
    gap: 18px;
    padding-top: 22px;
    border-top: 1px solid var(--hair);
    flex-wrap: wrap;
  }
  .byline {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .featured-meta .btn { margin-left: auto; }

  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1.5px solid var(--ink);
  }
  .cat-card {
    padding: 22px 20px;
    background: var(--paper);
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
    cursor: pointer;
    display: block;
  }
  .cat-card:hover { background: var(--paper-deep); }
  .cat-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .cat-n {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--graphite);
  }
  .cat-h {
    font-size: 20px;
    line-height: 1;
    margin-bottom: 16px;
  }
  .cat-desc {
    font-size: 12px;
    color: var(--graphite);
    margin-bottom: 12px;
    line-height: 1.5;
  }
  .cat-pick {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--orange-deep);
    font-weight: 700;
  }
  .cat-pick .dot {
    width: 6px; height: 6px;
    background: var(--orange);
  }

  .method-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 64px;
    align-items: start;
  }
  .method-cells {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  .method-cell {
    padding: 24px 28px 28px;
    border-top: 1px solid rgba(243,239,230,0.2);
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .recent-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    transition: opacity 0.12s;
  }
  .recent-card:hover { opacity: 0.7; }
  .recent-thumb {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border: 1.5px solid var(--ink);
    margin-bottom: 18px;
  }
  .recent-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 10px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .recent-kind {
    background: var(--ink);
    color: var(--paper);
    padding: 3px 7px;
  }
  .recent-title {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.22;
    margin: 0 0 14px;
    font-weight: 500;
  }

  .tipline {
    padding: 56px 28px;
    border-bottom: 1.5px solid var(--ink);
    background: var(--orange);
    color: var(--ink);
  }
  .tipline-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .tip-contact {
    padding: 28px 32px;
    background: var(--paper);
    border: 2px solid var(--ink);
  }
  .contact-email {
    display: block;
    font-family: var(--display);
    font-size: clamp(18px, 2.2vw, 24px);
    color: var(--ink);
    text-decoration: none;
    word-break: break-word;
  }
  .contact-email:hover { color: var(--orange-deep); }

  @media (max-width: 1023px) {
    .hero-grid { grid-template-columns: 1fr; }
    .featured { grid-template-columns: 1fr; gap: 32px; }
    .featured-stamp { position: static; margin-top: 16px; }
    .category-grid { grid-template-columns: repeat(2, 1fr); }
    .cat-card { border-right: 1px solid var(--hair) !important; border-bottom: 1px solid var(--hair) !important; }
    .cat-card:nth-child(2n) { border-right: none !important; }
    .method-grid { grid-template-columns: 1fr; gap: 32px; }
    .method-cells { grid-template-columns: 1fr; }
    .method-cell { border-left: none !important; }
    .recent-grid { grid-template-columns: repeat(2, 1fr); gap: 28px; }
    .tipline-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 767px) {
    .section, .section-dark, .hero, .tipline { padding: 40px 20px; }
    .category-grid { grid-template-columns: 1fr; }
    .cat-card { border-right: none !important; }
    .recent-grid { grid-template-columns: 1fr; }
    .hero-meta { margin-left: 0; margin-top: 10px; }
  }
</style>
