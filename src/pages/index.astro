        <div class="w-10 h-10 bg-[#FEFCE8] rounded-lg flex items-center justify-center text-lg shrink-0">🏗️</div>
        <div>
          <p class="font-semibold text-[#1C2B4B] text-sm group-hover:text-[#E07A3A] transition-colors">Estimating (GC)</p>
          <p class="text-[11px] text-gray-400">General contractors</p>
        </div>
      </a>

      <a href="/blog/best-scheduling-software-contractors/" class="group flex items-center gap-3 p-4 bg-white border border-gray-200 rounded-xl hover:border-[#E07A3A] hover:shadow-md transition-all duration-200">
        <div class="w-10 h-10 bg-[#ECFDF5] rounded-lg flex items-center justify-center text-lg shrink-0">📅</div>
        <div>
