---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildCategorySummaries } from '../../lib/content';

const reviews = await getCollection('reviews');
const roundups = await getCollection('roundups');
const comparisons = await getCollection('comparisons');
const categories = buildCategorySummaries(reviews, roundups, comparisons);
---
<BaseLayout
  title="Categories · Contractor Software Hub"
  description="Browse contractor software coverage by category and trade."
  active="categories"
>
  <section class="page-hero">
    <div class="wrap">
      <div class="rule-label" style="margin-bottom:24px;">
        <span>Categories</span>
        <span style="flex:1;"></span>
        <span>{categories.length} category pages</span>
      </div>
      <h1 class="display title">Browse by category.</h1>
      <p class="serif lede">Roundups, reviews, and comparisons grouped by the kind of software contractors are actually shopping for.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap grid">
      {categories.map((category) => (
        <a href={`/categories/${category.slug}/`} class="card">
          <div class="pill ghost" style="margin-bottom:12px;">{category.title}</div>
          <h2 class="display card-title">{category.title}</h2>
          <p class="serif card-desc">{category.description}</p>
          <div class="meta-row">
            <span>{category.roundups} roundups</span>
            <span>{category.reviews} reviews</span>
            <span>{category.comparisons} comparisons</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding: 48px 28px 36px; border-bottom: 1.5px solid var(--ink); }
  .title { font-size: clamp(44px, 6vw, 82px); line-height: 0.92; margin: 0 0 16px; }
  .lede { max-width: 760px; font-size: 18px; line-height: 1.5; color: var(--ink-2); }
  .section { padding: 56px 28px 72px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .card { display: flex; flex-direction: column; text-decoration: none; color: var(--ink); background: var(--paper); border: 1.5px solid var(--ink); padding: 24px; }
  .card:hover { background: var(--paper-deep); }
  .card-title { font-size: clamp(22px, 2.4vw, 28px); line-height: 1; margin: 0 0 12px; }
  .card-desc { font-size: 15px; line-height: 1.5; color: var(--ink-2); margin: 0 0 18px; }
  .meta-row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: auto; font-family: var(--mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--graphite); }
  @media (max-width: 1023px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 767px) { .page-hero, .section { padding-left: 20px; padding-right: 20px; } .grid { grid-template-columns: 1fr; } }
</style>
