---
import { getCollection } from 'astro:content';
import ReviewPage from '../components/ReviewPage.astro';
import ComparisonPage from '../components/ComparisonPage.astro';
import RoundupPage from '../components/RoundupPage.astro';
import GuidePage from '../components/GuidePage.astro';
import {
  reviewRootSlug,
  comparisonRootSlug,
  roundupRootSlug,
  guideRootSlug,
  roundupIdFromRootSlug,
} from '../lib/slugs';

export async function getStaticPaths() {
  const [guides, reviews, comparisons, roundups] = await Promise.all([
    getCollection('guides'),
    getCollection('reviews'),
    getCollection('comparisons'),
    getCollection('roundups'),
  ]);

  const paths = [];

  for (const entry of guides) {
    paths.push({
      params: { slug: guideRootSlug(entry.id) },
      props: { entry, kind: 'guide' },
    });
  }

  for (const entry of reviews) {
    paths.push({
      params: { slug: reviewRootSlug(entry.id) },
      props: { entry, kind: 'review' },
    });
  }

  for (const entry of comparisons) {
    paths.push({
      params: { slug: comparisonRootSlug(entry.id) },
      props: { entry, kind: 'comparison' },
    });
  }

  for (const entry of roundups) {
    paths.push({
      params: { slug: roundupRootSlug(entry.id) },
      props: { entry, kind: 'roundup' },
    });
  }

  return paths;
}

const { entry, kind } = Astro.props;
---

{kind === 'guide' && <GuidePage entry={entry} />}
{kind === 'review' && <ReviewPage entry={entry} />}
{kind === 'comparison' && <ComparisonPage entry={entry} />}
{kind === 'roundup' && <RoundupPage entry={entry} />}
