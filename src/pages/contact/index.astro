---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact · Contractor Software Hub"
  description="Contact Contractor Software Hub. Tip line open for tool requests, corrections, and software horror stories."
>
  <section class="page-hero">
    <div class="wrap-content">
      <div class="rule-label" style="margin-bottom:24px;">
        <span>Contact</span>
        <span style="flex:1;"></span>
        <span>Tip line open</span>
      </div>
      <h1 class="display hero-title">
        Tell us what<br/>to cover next.
      </h1>
    </div>
  </section>

  <section class="section-pad">
    <div class="wrap-reading">
      <div class="contact-grid">
        <div>
          <h2 class="display">Email</h2>
          <a href="mailto:grant@contractorsoftwarehub.com" class="email">grant@contractorsoftwarehub.com</a>
          <p class="serif" style="font-size:16px; line-height:1.6; color:var(--ink-2); margin-top:16px;">
            The best way to reach us. We read everything, even if we can't reply to everything.
          </p>
        </div>
        <div>
          <h2 class="display">What to send</h2>
          <ul class="list">
            <li>A tool we should cover</li>
            <li>A tool you think we're wrong about</li>
            <li>A pricing change we should know about</li>
            <li>A correction — we'll fix and credit</li>
            <li>A software horror story you want dug into</li>
            <li>Affiliate partnership proposals (we're selective)</li>
          </ul>
        </div>
      </div>

      <div class="cta-note">
        <div class="eyebrow eyebrow-muted" style="margin-bottom:10px;">What we're not</div>
        <p class="serif" style="font-size:16px; line-height:1.6; color:var(--ink-2); margin:0;">
          We're not customer support for any of the tools we cover. If Jobber's down or Housecall Pro won't load your invoice, they've got support teams — email them, not us.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 64px 28px 36px;
    border-bottom: 1.5px solid var(--ink);
  }
  .hero-title {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.9;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .section-pad {
    padding: 56px 28px;
    border-bottom: 1.5px solid var(--ink);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .contact-grid h2 {
    font-family: var(--display);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1;
    text-transform: uppercase;
    margin: 0 0 18px;
  }
  .email {
    font-family: var(--display);
    font-size: clamp(20px, 2.4vw, 26px);
    color: var(--ink);
    text-decoration: none;
    word-break: break-word;
  }
  .email:hover { color: var(--orange-deep); }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .list li {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    padding-left: 22px;
    position: relative;
  }
  .list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--orange);
    font-family: var(--mono);
    font-weight: 700;
  }
  .cta-note {
    padding: 28px;
    border: 1.5px solid var(--ink);
    background: var(--paper-deep);
  }
  @media (max-width: 767px) {
    .contact-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
