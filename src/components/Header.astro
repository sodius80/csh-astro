---
---
<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div class="w-8 h-8 bg-[#1C2B4B] rounded-md flex items-center justify-center">
          <span class="text-white font-bold text-sm">CSH</span>
        </div>
        <span class="text-lg font-bold text-[#1C2B4B] hidden sm:inline">Contractor Software Hub</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition">Home</a>
        <div class="relative group">
          <button class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition flex items-center gap-1">
            Reviews
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-gray-200 p-4 w-64">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Software Reviews</p>
              <a href="/blog/jobber-review/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Jobber Review</a>
              <a href="/blog/housecall-pro-review/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Housecall Pro Review</a>
              <a href="/blog/servicetitan-review/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">ServiceTitan Review</a>
              <hr class="my-2">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Comparisons</p>
              <a href="/blog/jobber-vs-housecall-pro/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Jobber vs Housecall Pro</a>
              <a href="/blog/servicetitan-vs-jobber/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">ServiceTitan vs Jobber</a>
              <a href="/blog/housecall-pro-vs-fieldedge/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">HCP vs FieldEdge</a>
            </div>
          </div>
        </div>
        <div class="relative group">
          <button class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition flex items-center gap-1">
            By Trade
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-gray-200 p-4 w-56">
              <a href="/blog/hvac-software/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">HVAC Software</a>
              <a href="/blog/plumbing-software/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Plumbing Software</a>
              <a href="/blog/roofing-software/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Roofing Software</a>
              <a href="/blog/landscaping-software/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Landscaping Software</a>
              <a href="/blog/pest-control-software/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Pest Control Software</a>
              <a href="/blog/best-software-painting-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Painting Software</a>
            </div>
          </div>
        </div>
        <div class="relative group">
          <button class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition flex items-center gap-1">
            By Category
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-gray-200 p-4 w-56">
              <a href="/blog/best-estimating-software-small-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Estimating (Small)</a>
              <a href="/blog/best-estimating-software-general-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Estimating (GC)</a>
              <a href="/blog/best-scheduling-software-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">Scheduling</a>
              <a href="/blog/best-crm-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">CRM</a>
              <a href="/blog/best-cad-software-contractors/" class="block py-1.5 text-sm text-gray-700 hover:text-[#1C2B4B]">CAD Software</a>
            </div>
          </div>
        </div>
        <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition">About</a>
        <a href="/contact/" class="text-sm font-medium text-gray-600 hover:text-[#1C2B4B] transition">Contact</a>
      </nav>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md text-gray-600 hover:text-[#1C2B4B] hover:bg-gray-100 transition" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-gray-100 mt-2 pt-4">
      <a href="/" class="block py-2 text-sm font-medium text-gray-700 hover:text-[#1C2B4B]">Home</a>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-3 mb-1 px-1">Reviews</p>
      <a href="/blog/jobber-review/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Jobber</a>
      <a href="/blog/housecall-pro-review/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Housecall Pro</a>
      <a href="/blog/servicetitan-review/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">ServiceTitan</a>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-3 mb-1 px-1">Comparisons</p>
      <a href="/blog/jobber-vs-housecall-pro/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Jobber vs HCP</a>
      <a href="/blog/servicetitan-vs-jobber/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">ST vs Jobber</a>
      <a href="/blog/housecall-pro-vs-fieldedge/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">HCP vs FieldEdge</a>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-3 mb-1 px-1">By Trade</p>
      <a href="/blog/hvac-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">HVAC</a>
      <a href="/blog/plumbing-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Plumbing</a>
      <a href="/blog/roofing-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Roofing</a>
      <a href="/blog/landscaping-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Landscaping</a>
      <a href="/blog/pest-control-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Pest Control</a>
      <a href="/blog/best-software-painting-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Painting</a>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-3 mb-1 px-1">By Category</p>
      <a href="/blog/best-estimating-software-small-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Estimating (Small)</a>
      <a href="/blog/best-scheduling-software-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Scheduling</a>
      <a href="/blog/best-crm-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">CRM</a>
      <a href="/blog/best-cad-software-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">CAD</a>
      <hr class="my-3">
      <a href="/about/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B]">About</a>
      <a href="/contact/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B]">Contact</a>
    </div>
  </div>
</header>
