---
---
<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0">
        <div class="w-8 h-8 bg-[#1C2B4B] rounded-md flex items-center justify-center">
          <span class="text-white font-black text-xs tracking-tight">CSH</span>
        </div>
        <span class="text-base font-bold text-[#1C2B4B] hidden sm:inline leading-tight">Contractor<br class="hidden md:block" /><span class="hidden md:inline"> Software Hub</span><span class="inline md:hidden"> Software Hub</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">

        <!-- Reviews dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-[#1C2B4B] rounded-md hover:bg-gray-50 transition-colors">
            Reviews
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-xl border border-gray-200 p-4 w-72">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 px-1">Software Reviews</p>
              <a href="/blog/jobber-review/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">
                <span class="w-6 h-6 bg-[#e0f2fe] rounded text-xs font-bold text-[#0369a1] flex items-center justify-center">J</span>
                Jobber Review
              </a>
              <a href="/blog/housecall-pro-review/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">
                <span class="w-6 h-6 bg-[#fce7f3] rounded text-xs font-bold text-[#be185d] flex items-center justify-center">H</span>
                Housecall Pro Review
              </a>
              <a href="/blog/servicetitan-review/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">
                <span class="w-6 h-6 bg-[#e2e8f0] rounded text-xs font-bold text-[#475569] flex items-center justify-center shrink-0">ST</span>
                ServiceTitan Review
              </a>
              <div class="my-2 border-t border-gray-100"></div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 px-1">Head-to-Head</p>
              <a href="/blog/jobber-vs-housecall-pro/" class="block px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">Jobber vs Housecall Pro</a>
              <a href="/blog/servicetitan-vs-jobber/" class="block px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">ServiceTitan vs Jobber</a>
              <a href="/blog/housecall-pro-vs-fieldedge/" class="block px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]">HCP vs FieldEdge</a>
            </div>
          </div>
        </div>

        <!-- By Trade dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-[#1C2B4B] rounded-md hover:bg-gray-50 transition-colors">
            By Trade
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-xl border border-gray-200 p-3 w-52">
              <a href="/blog/hvac-software/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🔧</span>HVAC Software</a>
              <a href="/blog/plumbing-software/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🔩</span>Plumbing Software</a>
              <a href="/blog/roofing-software/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🏠</span>Roofing Software</a>
              <a href="/blog/landscaping-software/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🌿</span>Landscaping Software</a>
              <a href="/blog/pest-control-software/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🐛</span>Pest Control Software</a>
              <a href="/blog/best-software-painting-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🎨</span>Painting Software</a>
            </div>
          </div>
        </div>

        <!-- By Category dropdown -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 hover:text-[#1C2B4B] rounded-md hover:bg-gray-50 transition-colors">
            By Category
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <div class="bg-white rounded-xl shadow-xl border border-gray-200 p-3 w-56">
              <a href="/blog/best-estimating-software-small-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>📊</span>Estimating (Small)</a>
              <a href="/blog/best-estimating-software-general-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>🏗️</span>Estimating (GC)</a>
              <a href="/blog/best-scheduling-software-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>📅</span>Scheduling</a>
              <a href="/blog/best-crm-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>👥</span>CRM</a>
              <a href="/blog/best-cad-software-contractors/" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-gray-50 hover:text-[#1C2B4B]"><span>✏️</span>CAD Software</a>
            </div>
          </div>
        </div>

        <a href="/about/" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-[#1C2B4B] rounded-md hover:bg-gray-50 transition-colors">About</a>

        <!-- Start Here CTA -->
        <a href="#by-trade" class="ml-2 inline-flex items-center gap-1.5 px-4 py-2 bg-[#E07A3A] text-white text-sm font-semibold rounded-lg hover:bg-[#C05E20] transition-colors">
          Start Here →
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md text-gray-600 hover:text-[#1C2B4B] hover:bg-gray-100 transition" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-gray-100 mt-0 pt-3">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-2 mb-1 px-1">Reviews</p>
      <a href="/blog/jobber-review/" class="flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-[#1C2B4B] pl-2">
        <span class="w-5 h-5 bg-[#e0f2fe] rounded text-xs font-bold text-[#0369a1] flex items-center justify-center">J</span>Jobber
      </a>
      <a href="/blog/housecall-pro-review/" class="flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-[#1C2B4B] pl-2">
        <span class="w-5 h-5 bg-[#fce7f3] rounded text-xs font-bold text-[#be185d] flex items-center justify-center">H</span>Housecall Pro
      </a>
      <a href="/blog/servicetitan-review/" class="flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-[#1C2B4B] pl-2">
        <span class="w-5 h-5 bg-[#e2e8f0] rounded text-xs font-bold text-[#475569] flex items-center justify-center shrink-0">ST</span>ServiceTitan
      </a>

      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-3 mb-1 px-1">Comparisons</p>
      <a href="/blog/jobber-vs-housecall-pro/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">Jobber vs HCP</a>
      <a href="/blog/servicetitan-vs-jobber/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">ST vs Jobber</a>
      <a href="/blog/housecall-pro-vs-fieldedge/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">HCP vs FieldEdge</a>

      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-3 mb-1 px-1">By Trade</p>
      <a href="/blog/hvac-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🔧 HVAC</a>
      <a href="/blog/plumbing-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🔩 Plumbing</a>
      <a href="/blog/roofing-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🏠 Roofing</a>
      <a href="/blog/landscaping-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🌿 Landscaping</a>
      <a href="/blog/pest-control-software/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🐛 Pest Control</a>
      <a href="/blog/best-software-painting-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🎨 Painting</a>

      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-3 mb-1 px-1">By Category</p>
      <a href="/blog/best-estimating-software-small-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">📊 Estimating (Small)</a>
      <a href="/blog/best-estimating-software-general-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">🏗️ Estimating (GC)</a>
      <a href="/blog/best-scheduling-software-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">📅 Scheduling</a>
      <a href="/blog/best-crm-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">👥 CRM</a>
      <a href="/blog/best-cad-software-contractors/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B] pl-3">✏️ CAD Software</a>

      <div class="mt-3 border-t border-gray-100 pt-3 flex gap-3">
        <a href="/about/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B]">About</a>
        <a href="/contact/" class="block py-2 text-sm text-gray-600 hover:text-[#1C2B4B]">Contact</a>
      </div>
    </div>

  </div>
</header>
