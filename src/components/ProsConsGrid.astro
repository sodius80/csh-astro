---
interface Props {
  pros: string[];
  cons: string[];
  prosLabel?: string;
  consLabel?: string;
  dark?: boolean;
}
const { pros, cons, prosLabel = 'Works well', consLabel = 'Watch out for', dark = false } = Astro.props;
const bgLabel = dark ? 'var(--ink)' : 'var(--paper)';
---
<div class="pros-cons" data-dark={dark}>
  <div class="col pros">
    <div class="tab" style={`background:${bgLabel}; color: var(--orange-deep);`}>+ {prosLabel}</div>
    <ul>
      {pros.map(p => (
        <li><span class="mark">+</span><span>{p}</span></li>
      ))}
    </ul>
  </div>
  <div class="col cons">
    <div class="tab" style={`background:${bgLabel}; color: var(--red);`}>− {consLabel}</div>
    <ul>
      {cons.map(c => (
        <li class="con"><span class="mark">−</span><span>{c}</span></li>
      ))}
    </ul>
  </div>
</div>
<style>
  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .col {
    position: relative;
    padding: 24px;
    border: 1.5px solid var(--orange);
  }
  .col.cons { border-color: var(--red); }
  .pros-cons[data-dark='true'] .col { background: transparent; }
  .tab {
    position: absolute;
    top: -10px;
    left: 16px;
    padding: 0 10px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 700;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  li {
    display: flex;
    gap: 14px;
    font-family: var(--serif);
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .pros-cons[data-dark='true'] li { color: var(--paper); }
  .mark {
    color: var(--orange);
    font-family: var(--mono);
    font-size: 12px;
    margin-top: 3px;
    flex-shrink: 0;
  }
  .con .mark { color: var(--red); }
  @media (max-width: 767px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
