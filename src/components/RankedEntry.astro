---
import RatingStamp from './RatingStamp.astro';
import ProsConsGrid from './ProsConsGrid.astro';

interface Props {
  rank: number;
  name: string;
  slug?: string;
  rating: 'top-pick' | 'recommended' | 'conditional' | 'skip';
  tag: string;
  bestFor: string;
  startingPrice: string;
  pullquote: string;
  body: string;
  pros: string[];
  cons: string[];
  affiliateUrl?: string;
  isFirst?: boolean;
}
const {
  rank,
  name,
  slug,
  rating,
  tag,
  bestFor,
  startingPrice,
  pullquote,
  body,
  pros,
  cons,
  affiliateUrl,
  isFirst = false,
} = Astro.props;
const reviewUrl = slug ? `/reviews/${slug}/` : null;
const rotate = [-5, 3, -4, 4, -3, 2][(rank - 1) % 6];
---
<div class={`ranked ${isFirst ? 'first' : ''}`} id={`rank-${rank}`}>
  <div class="col-left">
    <div class="bignum">{String(rank).padStart(2, '0')}</div>
    <div class="stamp-wrap">
      <RatingStamp rating={rating} rotate={rotate} />
    </div>
  </div>
  <div class="col-right">
    <div class="head">
      <div>
        <div class="tag">{tag}</div>
        <h2 class="display name">{name}</h2>
        <div class="meta">
          <span>Best-fit · <strong>{bestFor}</strong></span>
          <span>From · <strong>{startingPrice}</strong></span>
        </div>
      </div>
      <div class="ctas">
        {reviewUrl && <a href={reviewUrl} class="btn outline sm">Read review →</a>}
        {affiliateUrl && <a href={affiliateUrl} class="btn orange sm" rel="sponsored nofollow noopener" target="_blank">Try {name} →</a>}
      </div>
    </div>
    <blockquote class="pullquote">"{pullquote}"</blockquote>
    <p class="body">{body}</p>
    <ProsConsGrid pros={pros} cons={cons} />
  </div>
</div>

<style>
  .ranked {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 36px;
    padding: 40px 0;
    border-top: 1px solid var(--hair);
  }
  .ranked.first { border-top: 1.5px solid var(--ink); }
  .bignum {
    font-family: var(--display);
    font-size: clamp(64px, 8vw, 96px);
    line-height: 0.85;
    color: var(--orange);
    letter-spacing: -0.02em;
  }
  .stamp-wrap { margin-top: 16px; }
  .head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 20px;
  }
  .tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange-deep);
    margin-bottom: 8px;
    font-weight: 700;
  }
  .name {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 0.9;
    margin: 0 0 12px;
  }
  .meta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--graphite);
  }
  .meta strong { color: var(--ink); font-weight: 700; }
  .ctas {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .pullquote {
    padding: 18px 24px;
    border-left: 3px solid var(--orange);
    background: var(--paper-deep);
    margin: 0 0 22px;
    font-family: var(--serif);
    font-size: 17px;
    font-style: italic;
    line-height: 1.4;
    color: var(--ink);
  }
  .body {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 22px;
  }
  @media (max-width: 767px) {
    .ranked { grid-template-columns: 1fr; gap: 20px; padding: 32px 0; }
    .head { grid-template-columns: 1fr; }
    .ctas { width: 100%; }
  }
</style>
