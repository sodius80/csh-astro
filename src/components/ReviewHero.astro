---
interface Props {
  category: string;
  title: string;
  subtitle?: string;
  cta_url: string;
  cta_text: string;
  pricing?: string;
  best_for?: string;
  researchDate: string;
  disclosure?: string;
  verdictBadge?: string;
}

const {
  category,
  title,
  subtitle,
  cta_url,
  cta_text,
  pricing,
  best_for,
  researchDate,
  disclosure = "There are currently no affiliate links in this article. If that changes later, it will not affect how I evaluate the tools.",
  verdictBadge = "ROUNDUP"
} = Astro.props;
---

<!-- Affiliate Disclosure -->
<div class="disclosure-bar">
  <svg class="disclosure-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
  <p><strong>Disclosure:</strong> {disclosure}</p>
</div>

<!-- Hero -->
<div class="review-hero">
  <div class="review-hero-inner">

    <!-- Category + Verdict -->
    <div class="review-hero-top">
      <span class="review-eyebrow">{category}</span>
      <span class="review-verdict-badge">✔ {verdictBadge}</span>
    </div>

    <!-- Title -->
    <h1 class="review-title">{title}</h1>
    {subtitle && <p class="review-subtitle">{subtitle}</p>}

    <!-- Meta strip -->
    <div class="review-meta">
      <span class="review-meta-item">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
        Updated <strong>{researchDate}</strong>
      </span>
      {pricing && (
        <span class="review-meta-item">
          <svg viewBox="0 0 20 20" fill="currentColor"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/></svg>
          Pricing: <strong>{pricing}</strong>
        </span>
      )}
      {best_for && (
        <span class="review-meta-item">
          <svg viewBox="0 0 20 20" fill="currentColor"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          Best for: <strong>{best_for}</strong>
        </span>
      )}
    </div>

    <!-- CTA -->
    {cta_url && cta_url !== '/' && (
      <a href={cta_url} class="review-cta" rel="nofollow sponsored">{cta_text}</a>
    )}

  </div>
</div>

<style>
  /* ── Disclosure bar ──────────────────────────── */
  .disclosure-bar {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #FFFBEB;
    border: 1px solid #FDE68A;
    border-left: 4px solid #E07A3A;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 13px;
    color: #4B3C28;
    line-height: 1.55;
    margin-bottom: 0;
  }
  .disclosure-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 1px;
    color: #E07A3A;
  }
  .disclosure-bar strong { font-weight: 700; }

  /* ── Hero ───────────────────────────────────── */
  .review-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1C2B4B 100%);
    color: white;
    padding: 2.5rem 2rem;
    margin-top: 0;
    border-radius: 0 0 16px 16px;
    position: relative;
    overflow: hidden;
  }
  /* Dot grid texture */
  .review-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 22px 22px;
    pointer-events: none;
  }
  .review-hero-inner {
    position: relative;
    max-width: 900px;
  }

  /* ── Top row (eyebrow + badge) ──────────────── */
  .review-hero-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .review-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #E07A3A;
    background: rgba(224, 122, 58, 0.15);
    border: 1px solid rgba(224, 122, 58, 0.3);
    border-radius: 100px;
    padding: 3px 12px;
  }
  .review-verdict-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    padding: 3px 12px;
  }

  /* ── Title ──────────────────────────────────── */
  .review-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    color: white;
    margin: 0 0 0.6rem 0;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .review-subtitle {
    color: rgba(255,255,255,0.75);
    margin: 0 0 1.5rem 0;
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 650px;
  }

  /* ── Meta strip ─────────────────────────────── */
  .review-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
    margin-bottom: 1.75rem;
    padding: 12px 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    width: fit-content;
  }
  .review-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
  }
  .review-meta-item svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: #E07A3A;
  }
  .review-meta-item strong {
    color: white;
    font-weight: 600;
  }

  /* ── CTA button ─────────────────────────────── */
  .review-cta {
    display: inline-flex;
    align-items: center;
    background: #E07A3A;
    color: white;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 4px 12px rgba(224, 122, 58, 0.35);
  }
  .review-cta:hover {
    background: #C05E20;
    transform: translateY(-1px);
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 640px) {
    .review-hero { padding: 2rem 1.25rem; }
    .review-title { font-size: 1.5rem; }
    .review-meta { gap: 0.75rem 1rem; }
    .review-cta { width: 100%; text-align: center; justify-content: center; }
  }
</style>
