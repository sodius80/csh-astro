---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'reviews' | 'comparisons' | 'bestof' | 'finder' | 'categories' | 'about' | 'how';
  canonical?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Honest, independent software coverage for contractors in the trades.',
  active = 'home',
  canonical,
  ogImage,
} = Astro.props;
const siteUrl = 'https://www.contractorsoftwarehub.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const defaultOgImage = '/images/csh-og-default.png';
const resolvedOgImage = ogImage && typeof ogImage === 'string' ? new URL(ogImage, siteUrl).toString() : new URL(defaultOgImage, siteUrl).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-5L9PZVWY24"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    var consent = localStorage.getItem('csh_cookie_consent');
    gtag('js', new Date());
    gtag('config', 'G-5L9PZVWY24', {
      'anonymize_ip': true,
      'send_page_view': consent === 'accepted'
    });
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'analytics_storage': consent === 'accepted' ? 'granted' : 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied'
    });
  </script>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <SiteHeader active={active} />
  <main><slot /></main>
  <SiteFooter />
  
  <!-- Cookie Consent Banner -->
  <div id="csh-cookie-banner" style="position:fixed;bottom:0;left:0;right:0;background:#1a2332;color:#fff;padding:16px 20px;z-index:9999;font-size:14px;line-height:1.5;display:none;">
    <div style="max-width:1200px;margin:0 auto;display:flex;gap:16px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
      <span style="flex:1;min-width:280px;">We use cookies to improve your experience and deliver personalized content. By continuing, you agree to our <a href="/privacy-policy/" style="color:#4dabf7;text-decoration:underline;">Privacy Policy</a> and <a href="/terms-of-service/" style="color:#4dabf7;text-decoration:underline;">Terms of Service</a>.</span>
      <div style="display:flex;gap:10px;flex-shrink:0;">
        <button onclick="cshCookieAccept()" style="background:#2ecc71;color:#fff;border:none;padding:8px 20px;border-radius:4px;cursor:pointer;font-weight:600;">Accept</button>
        <button onclick="cshCookieDecline()" style="background:transparent;color:#adb5bd;border:1px solid #495057;padding:8px 16px;border-radius:4px;cursor:pointer;">Close</button>
      </div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var consent = localStorage.getItem('csh_cookie_consent');
      if (!consent) {
        document.getElementById('csh-cookie-banner').style.display = 'block';
      }
        window.cshCookieAccept = function() {
        localStorage.setItem('csh_cookie_consent', 'accepted');
        document.getElementById('csh-cookie-banner').style.display = 'none';
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'analytics_storage': 'granted'
          });
          gtag('event', 'page_view');
        }
      };
      window.cshCookieDecline = function() {
        localStorage.setItem('csh_cookie_consent', 'declined');
        document.getElementById('csh-cookie-banner').style.display = 'none';
      };
    })();
  </script>
</body>
</html>
