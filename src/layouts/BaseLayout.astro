---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'reviews' | 'comparisons' | 'bestof' | 'finder' | 'categories' | 'about' | 'how';
  canonical?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Honest, independent software coverage for contractors in the trades.',
  active = 'home',
  canonical,
  ogImage,
} = Astro.props;
const siteUrl = 'https://contractorsoftwarehub.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const defaultOgImage = '/images/csh-og-default.png';
const resolvedOgImage = ogImage && typeof ogImage === 'string' ? new URL(ogImage, siteUrl).toString() : new URL(defaultOgImage, siteUrl).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <SiteHeader active={active} />
  <main><slot /></main>
  <SiteFooter />
</body>
</html>
