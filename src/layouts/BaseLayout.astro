---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'reviews' | 'comparisons' | 'bestof' | 'finder' | 'categories' | 'about' | 'how';
  canonical?: string;
  ogImage?: string;
  schema?: string | string[];
  pubDate?: Date;
  updatedDate?: Date;
}
const {
  title,
  description = 'Honest, independent software coverage for contractors in the trades.',
  active = 'home',
  canonical,
  ogImage,
  schema,
  pubDate,
  updatedDate,
} = Astro.props;
const siteUrl = 'https://www.contractorsoftwarehub.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const defaultOgImage = '/images/csh-og-default.png';
const resolvedOgImage = ogImage && typeof ogImage === 'string' ? new URL(ogImage, siteUrl).toString() : new URL(defaultOgImage, siteUrl).toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="fo-verify" content="3d413dd5-edcc-4dc0-80cf-582b3606ec62" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" is:inline />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-5L9PZVWY24"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    var consent = localStorage.getItem('csh_cookie_consent');
    gtag('js', new Date());
    gtag('config', 'G-5L9PZVWY24', {
      'anonymize_ip': true,
      'send_page_view': consent === 'accepted'
    });
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'analytics_storage': consent === 'accepted' ? 'granted' : 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied'
    });
  </script>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {schema &&
    (Array.isArray(schema) ? schema : [schema]).map((s) => (
      <script type="application/ld+json" set:html={s} />
    ))
  }
</head>
<body>
  <SiteHeader active={active} />
  <main><slot /></main>
  <SiteFooter />
  
  <!-- Cookie Consent Banner -->
  <div id="csh-cookie-banner" style="position:fixed;bottom:0;left:0;right:0;background:#1a2332;color:#fff;padding:16px 20px;z-index:9999;font-size:14px;line-height:1.5;display:none;">
    <div style="max-width:1200px;margin:0 auto;display:flex;gap:16px;align-items:center;justify-content:space-between;flex-wrap:wrap;">
      <span style="flex:1;min-width:280px;">We use cookies to improve your experience and deliver personalized content. By continuing, you agree to our <a href="/privacy-policy/" style="color:#4dabf7;text-decoration:underline;">Privacy Policy</a> and <a href="/terms-of-service/" style="color:#4dabf7;text-decoration:underline;">Terms of Service</a>.</span>
      <div style="display:flex;gap:10px;flex-shrink:0;">
        <button onclick="cshCookieAccept()" style="background:#2ecc71;color:#fff;border:none;padding:8px 20px;border-radius:4px;cursor:pointer;font-weight:600;">Accept</button>
        <button onclick="cshCookieDecline()" style="background:transparent;color:#adb5bd;border:1px solid #495057;padding:8px 16px;border-radius:4px;cursor:pointer;">Close</button>
      </div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var consent = localStorage.getItem('csh_cookie_consent');
      if (!consent) {
        document.getElementById('csh-cookie-banner').style.display = 'block';
      }
        window.cshCookieAccept = function() {
        localStorage.setItem('csh_cookie_consent', 'accepted');
        document.getElementById('csh-cookie-banner').style.display = 'none';
        if (typeof gtag !== 'undefined') {
          gtag('consent', 'update', {
            'analytics_storage': 'granted'
          });
          gtag('event', 'page_view');
        }
      };
      window.cshCookieDecline = function() {
        localStorage.setItem('csh_cookie_consent', 'declined');
        document.getElementById('csh-cookie-banner').style.display = 'none';
      };
    })();
  </script>

  <!-- Site Search (Pagefind) -->
  <div id="csh-search" class="csh-search-overlay" style="display:none;" role="dialog" aria-label="Search">
    <div class="csh-search-inner">
      <div class="csh-search-header">
        <span class="csh-search-label">Search</span>
        <button class="csh-search-close" onclick="cshCloseSearch()" aria-label="Close search">&times;</button>
      </div>
      <div id="csh-search-ui"></div>
    </div>
  </div>
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    (function() {
      var pfu;
      document.addEventListener('DOMContentLoaded', function() {
        pfu = new PagefindUI({
          element: "#csh-search-ui",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
      });
      window.cshOpenSearch = function() {
        var overlay = document.getElementById('csh-search');
        if (overlay) {
          overlay.style.display = 'flex';
          document.body.style.overflow = 'hidden';
          setTimeout(function() {
            var input = document.querySelector('.pagefind-ui__search-input');
            if (input) { input.focus(); }
          }, 150);
        }
      };
      window.cshCloseSearch = function() {
        var overlay = document.getElementById('csh-search');
        if (overlay) {
          overlay.style.display = 'none';
          document.body.style.overflow = '';
        }
      };
      // Close on Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          var overlay = document.getElementById('csh-search');
          if (overlay && overlay.style.display !== 'none') {
            cshCloseSearch();
          }
        }
      });
    })();
  </script>
  <style is:global>
    .csh-search-overlay {
      position: fixed; top: 0; left: 0; right: 0; bottom: 0;
      z-index: 10000;
      background: rgba(26, 35, 50, 0.88);
      display: none; align-items: flex-start; justify-content: center;
      padding: 80px 20px;
      backdrop-filter: blur(4px);
    }
    .csh-search-inner {
      background: #f3efe6;
      width: 100%; max-width: 640px;
      max-height: calc(100vh - 160px);
      border-radius: 8px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      overflow-x: hidden;
      overflow-y: auto;
      display: flex; flex-direction: column;
    }
    .csh-search-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px 0;
      flex-shrink: 0;
    }
    .csh-search-label {
      font-family: 'SF Mono', 'Menlo', monospace;
      font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
      color: #1a2332; font-weight: 600;
    }
    .csh-search-close {
      background: none; border: none;
      font-size: 24px; color: #1a2332;
      cursor: pointer; padding: 0 4px; line-height: 1;
      opacity: 0.5; transition: opacity 0.12s;
    }
    .csh-search-close:hover { opacity: 1; }
    .csh-search-inner .pagefind-ui {
      padding: 0 20px 20px;
      flex: 1;
      min-height: 0;
    }
    .csh-search-inner .pagefind-ui__search-input {
      border: 1.5px solid #1a2332; border-radius: 4px;
      padding: 10px 14px 10px 36px; font-size: 16px;
      background: #fff; color: #1a2332;
    }
    .csh-search-inner .pagefind-ui__search-input:focus {
      outline: none; box-shadow: 0 0 0 2px rgba(230, 126, 34, 0.3);
      border-color: #e67e22;
    }
    .csh-search-inner .pagefind-ui__result-title {
      color: #1a2332; font-weight: 600;
    }
    .csh-search-inner .pagefind-ui__result-excerpt {
      color: #5a5a5a; font-size: 13px;
    }
    .csh-search-inner .pagefind-ui__result-excerpt mark {
      background: rgba(230, 126, 34, 0.2); color: #1a2332;
    }
    .csh-search-inner .pagefind-ui__result {
      border-bottom: 1px solid #ddd8cc; padding: 12px 0;
    }
    .csh-search-inner .pagefind-ui__button {
      background: #1a2332; color: #f3efe6;
      border: none; padding: 8px 16px; border-radius: 4px;
      cursor: pointer; font-size: 13px;
    }
    .csh-search-inner .pagefind-ui__message {
      color: #5a5a5a; font-size: 13px;
    }
  </style>
</body>
</html>
