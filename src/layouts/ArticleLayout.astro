---
import Layout from './Layout.astro';
import ReviewHero from '../components/ReviewHero.astro';

interface Props {
  title: string;
  description: string;
  hero?: {
    eyebrow: string;
    subtitle?: string;
    cta_url: string;
    cta_text: string;
    pricing?: string;
    best_for?: string;
    disclosure_override?: string;
  };
  researchDate: string;
}

const { title, description, hero, researchDate } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    {hero && (
      <ReviewHero
        category={hero.eyebrow}
        title={title}
        subtitle={hero.subtitle}
        cta_url={hero.cta_url}
        cta_text={hero.cta_text}
        pricing={hero.pricing}
        best_for={hero.best_for}
        disclosure={hero.disclosure_override}
        researchDate={researchDate}
      />
    )}

    <article class="article-content">
      <slot />
    </article>
  </div>
</Layout>

<style>
  /* Article content styling */
  :global(.article-content h2) {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1C2B4B;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  :global(.article-content h3) {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #1C2B4B;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  :global(.article-content p) {
    margin-bottom: 1rem;
    line-height: 1.75;
    color: #374151;
  }
  :global(.article-content ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  :global(.article-content li) {
    margin-bottom: 0.35rem;
    line-height: 1.6;
  }
  :global(.article-content strong) {
    color: #1C2B4B;
  }
  :global(.article-content hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
  :global(.article-content blockquote) {
    border-left: 4px solid #1C2B4B;
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #6b7280;
  }
  :global(.article-content figure) {
    margin: 1.5rem 0;
  }
  :global(.article-content img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
  /* FAQ section */
  :global(.article-content h3) {
    scroll-margin-top: 5rem;
  }
  :global(.article-content h2) {
    scroll-margin-top: 5rem;
  }
</style>
