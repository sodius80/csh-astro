---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {title && <title>{title} — Contractor Software Hub</title>}
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased bg-white text-gray-800 flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* ── Design Tokens ─────────────────────────────────── */
  :root {
    --navy:        #1C2B4B;
    --navy-deep:   #0f172a;
    --orange:      #E07A3A;
    --orange-dark: #C05E20;
    --gray-50:     #F8F9FB;
    --gray-100:    #F0F2F5;
    --gray-200:    #E2E6EC;
    --gray-500:    #7A8494;
    --gray-700:    #3A4558;
    --gray-900:    #141C2E;
    --font-sans:   'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-display:'Barlow Condensed', var(--font-sans);
    --radius-sm:   6px;
    --radius:      10px;
    --radius-lg:   16px;
    --radius-xl:   20px;
  }

  /* ── Base ──────────────────────────────────────────── */
  body {
    font-family: var(--font-sans);
    color: var(--gray-700);
    line-height: 1.65;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    color: var(--navy);
    line-height: 1.2;
  }

  /* ── Tables ────────────────────────────────────────── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--gray-200);
  }
  th {
    background-color: var(--navy);
    color: white;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--gray-200);
    color: var(--gray-700);
  }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background-color: var(--gray-50); }
  tr:hover td { background-color: #FFF3EA; }

  /* ── Code ──────────────────────────────────────────── */
  code {
    background: var(--gray-100);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }

  /* ── Article links ─────────────────────────────────── */
  article a {
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  article a:hover { color: var(--orange); }

  /* ── Smooth scroll ─────────────────────────────────── */
  html { scroll-behavior: smooth; }

  /* ── Focus ─────────────────────────────────────────── */
  :focus-visible {
    outline: 2px solid var(--orange);
    outline-offset: 2px;
  }
</style>
